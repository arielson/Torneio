@model IEnumerable<FiscalDto>
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    var torneio = ViewBag.Torneio as TorneioDto;
    var equipes = (IEnumerable<EquipeDto>)(ViewBag.Equipes ?? Enumerable.Empty<EquipeDto>());
    var label = torneio?.LabelSupervisor ?? "Fiscal";
    var labelPlural = torneio?.LabelSupervisorPlural ?? "Fiscais";
    var labelEquipePlural = torneio?.LabelEquipePlural ?? "Equipes";
    ViewData["Title"] = labelPlural;
    var lista = Model.ToList();
    var equipesPorId = equipes.ToDictionary(e => e.Id, e => e.Nome);
    var storageBase = ViewBag.StorageBaseUrl as string ?? "";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>@labelPlural</h1>
    </div>
    <div class="page-header-actions">
        <a href="/@slug/fiscais/criar" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Novo @label
        </a>
    </div>
</div>
<a href="/@slug/admin" class="back-link">
    <i class="bi bi-arrow-left"></i> Painel
</a>

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-person-badge me-2"></i>@labelPlural cadastrados</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">
            Nenhum @label.ToLower() cadastrado. <a href="/@slug/fiscais/criar">Criar o primeiro</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="width:48px"></th>
                        <th>Nome</th>
                        <th>Usuário</th>
                        <th>@labelEquipePlural</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in lista)
                    {
                        var nomesEquipes = f.EquipeIds
                            .Where(equipesPorId.ContainsKey)
                            .Select(id => equipesPorId[id])
                            .OrderBy(nome => nome)
                            .ToList();
                        var fotoFiscal = string.IsNullOrWhiteSpace(f.FotoUrl) ? null
                            : (f.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? f.FotoUrl : $"{storageBase}/{f.FotoUrl.TrimStart('/')}");
                        <tr>
                            <td>
                                @if (fotoFiscal != null)
                                {
                                    <img src="@fotoFiscal" alt="@f.Nome"
                                         class="rounded-circle foto-thumb"
                                         style="width:36px;height:36px;object-fit:cover;cursor:pointer;"
                                         data-src="@fotoFiscal" data-nome="@f.Nome"
                                         onerror="this.replaceWith(document.getElementById('avatar-tpl').content.cloneNode(true))" />
                                }
                                else
                                {
                                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary text-white"
                                          style="width:36px;height:36px;font-size:.85rem">
                                        <i class="bi bi-person-badge"></i>
                                    </span>
                                }
                            </td>
                            <td class="fw-semibold">@f.Nome</td>
                            <td><code class="text-muted small">@f.Usuario</code></td>
                            <td>
                                @if (!nomesEquipes.Any())
                                {
                                    <span class="text-muted small">Nenhuma</span>
                                }
                                else
                                {
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var nomeEquipe in nomesEquipes)
                                        {
                                            <span class="badge text-bg-light border">@nomeEquipe</span>
                                        }
                                    </div>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/@slug/fiscais/@f.Id/editar" class="btn btn-sm btn-outline-primary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="/@slug/fiscais/@f.Id/senha" class="btn btn-sm btn-outline-secondary" title="Alterar senha">
                                        <i class="bi bi-key"></i>
                                    </a>
                                    <form asp-controller="Fiscal" asp-action="Remover" asp-route-slug="@slug" asp-route-id="@f.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remover @f.Nome?')" title="Remover">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<template id="avatar-tpl">
    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary text-white"
          style="width:36px;height:36px;font-size:.85rem">
        <i class="bi bi-person-badge"></i>
    </span>
</template>

<div class="modal fade" id="modalFoto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 bg-transparent shadow-none">
            <div class="modal-body p-0 text-center">
                <img id="modalFotoImg" src="" alt="" class="img-fluid rounded" style="max-height:80vh;" />
                <p id="modalFotoNome" class="text-white mt-2 fw-semibold fs-5 mb-0"></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    (() => {
        const modal     = new bootstrap.Modal(document.getElementById('modalFoto'));
        const modalImg  = document.getElementById('modalFotoImg');
        const modalNome = document.getElementById('modalFotoNome');
        document.querySelectorAll('.foto-thumb').forEach(img => {
            img.addEventListener('click', () => {
                modalImg.src = img.dataset.src;
                modalImg.alt = img.dataset.nome;
                modalNome.textContent = img.dataset.nome;
                modal.show();
            });
        });
    })();
    </script>
}
