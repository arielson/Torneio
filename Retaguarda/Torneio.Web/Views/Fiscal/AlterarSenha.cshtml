@model AtualizarSenhaDto
@{
    var slug   = Context.GetRouteData().Values["slug"]?.ToString();
    var anoId  = (Guid)ViewBag.AnoId;
    var fiscal = (FiscalDto)ViewBag.Fiscal;
    ViewData["Title"] = $"Alterar Senha — {fiscal.Nome}";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Alterar Senha — @fiscal.Nome</h1>
    </div>
</div>
<a href="/@slug/fiscais/@anoId" class="back-link">
    <i class="bi bi-arrow-left"></i> Fiscais
</a>

<div class="form-card">
    <form asp-controller="Fiscal" asp-action="AlterarSenha" asp-route-slug="@slug" asp-route-anoId="@anoId" asp-route-id="@fiscal.Id" method="post">
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }
        <div class="form-section-title">Nova Senha</div>
        <div class="mb-3">
            <label asp-for="SenhaAtual" class="form-label">Senha Atual</label>
            <input asp-for="SenhaAtual" class="form-control" type="password" />
            <span asp-validation-for="SenhaAtual" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="NovaSenha" class="form-label">Nova Senha</label>
            <input asp-for="NovaSenha" class="form-control" type="password" />
            <span asp-validation-for="NovaSenha" class="text-danger small"></span>
        </div>
        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Salvar Senha
            </button>
            <a href="/@slug/fiscais/@anoId" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
