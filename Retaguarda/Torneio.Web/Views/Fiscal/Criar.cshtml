@model CriarFiscalDto
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    var torneio = ViewBag.Torneio as TorneioDto;
    var equipes = (IEnumerable<EquipeDto>)(ViewBag.Equipes ?? Enumerable.Empty<EquipeDto>());
    var label = torneio?.LabelSupervisor ?? "Fiscal";
    var labelPlural = torneio?.LabelSupervisorPlural ?? "Fiscais";
    var labelEquipePlural = torneio?.LabelEquipePlural ?? "Equipes";
    var labelEquipe = torneio?.LabelEquipe ?? "Equipe";
    ViewData["Title"] = $"Novo {label}";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Novo @label</h1>
    </div>
</div>
<a href="/@slug/fiscais" class="back-link">
    <i class="bi bi-arrow-left"></i> @labelPlural
</a>

<div class="form-card">
    <form asp-controller="Fiscal" asp-action="Criar" asp-route-slug="@slug" method="post" enctype="multipart/form-data">
        <input asp-for="TorneioId" type="hidden" />
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }
        <div class="form-section-title">Dados do @label</div>
        <div class="mb-3">
            <label asp-for="Nome" class="form-label">Nome</label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>
        <div class="form-section-title">Acesso</div>
        <div class="mb-3">
            <label asp-for="Usuario" class="form-label">Usuário</label>
            <input asp-for="Usuario" class="form-control" autocomplete="username" />
            <span asp-validation-for="Usuario" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Senha" class="form-label">Senha</label>
            <input asp-for="Senha" class="form-control" type="password" autocomplete="new-password" />
            <span asp-validation-for="Senha" class="text-danger small"></span>
        </div>
        <div class="form-section-title">@labelEquipePlural atendidas</div>
        <div class="mb-3">
            @{
                var equipeDtos = equipes.ToList();
            }
            @if (!equipeDtos.Any())
            {
                <div class="text-muted small">Nenhuma @labelEquipe.ToLower() cadastrada no torneio.</div>
            }
            else
            {
                @foreach (var equipe in equipeDtos.OrderBy(e => e.Nome))
                {
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="EquipeIds" value="@equipe.Id" id="eq_@equipe.Id"
                               @(Model.EquipeIds.Contains(equipe.Id) ? "checked" : null) />
                        <label class="form-check-label" for="eq_@equipe.Id">@equipe.Nome</label>
                    </div>
                }
            }
        </div>
        <div class="form-section-title">Foto</div>
        <partial name="_FotoUpload" view-data='@(new ViewDataDictionary(ViewData) { { "inputName", "foto" }, { "label", $"Foto do {label}" } })' />
        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Criar @label
            </button>
            <a href="/@slug/fiscais" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
