@model AtualizarMembroDto
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    var membro = (MembroDto)ViewBag.Membro;
    var torneio = (TorneioDto)ViewBag.Torneio;
    var label = torneio?.LabelMembro ?? "Membro";
    var labelPlural = torneio?.LabelMembroPlural ?? "Membros";
    var tamanhosBase = new[] { "", "PP", "P", "M", "G", "GG", "XGG", "EXGG" };
    var tamanhosCamisa = tamanhosBase.Contains(Model.TamanhoCamisa ?? string.Empty)
        ? tamanhosBase
        : tamanhosBase.Concat(new[] { Model.TamanhoCamisa ?? string.Empty }).Distinct().ToArray();
    var exibirFinanceiro = torneio?.ExibirModuloFinanceiro ?? true;
    ViewData["Title"] = $"Editar {label} - {membro.Nome}";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Editar @label - @membro.Nome</h1>
    </div>
</div>
<a href="/@slug/membros" class="back-link">
    <i class="bi bi-arrow-left"></i> @labelPlural
</a>

<div class="form-card">
    <form asp-controller="Membro" asp-action="Editar" asp-route-slug="@slug" asp-route-id="@membro.Id" method="post" enctype="multipart/form-data">
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }
        <div class="form-section-title">Dados do @label</div>
        <div class="mb-3">
            <label asp-for="Nome" class="form-label">Nome do @label</label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Celular" class="form-label">Celular</label>
            <input asp-for="Celular" class="form-control" placeholder="Opcional" inputmode="numeric" maxlength="15" />
            <span asp-validation-for="Celular" class="text-danger small"></span>
        </div>
        @if (exibirFinanceiro)
        {
            <div class="mb-3">
                <label asp-for="TamanhoCamisa" class="form-label">Tamanho da camisa</label>
                <select asp-for="TamanhoCamisa" class="form-select">
                    @foreach (var tamanho in tamanhosCamisa)
                    {
                        <option value="@tamanho">@(string.IsNullOrEmpty(tamanho) ? "Nao informado" : tamanho)</option>
                    }
                </select>
                <span asp-validation-for="TamanhoCamisa" class="text-danger small"></span>
            </div>
        }
        else
        {
            <input asp-for="TamanhoCamisa" type="hidden" value="@Model.TamanhoCamisa" />
        }
        <div class="form-section-title">Foto</div>
        <partial name="_FotoUpload" view-data='@(new ViewDataDictionary(ViewData) { { "inputName", "foto" }, { "label", $"Foto do {label}" }, { "fotoUrl", membro.FotoUrl } })' />
        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Salvar alteracoes
            </button>
            <a href="/@slug/membros" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const input = document.getElementById('Celular');
            if (!input) return;

            const formatarCelular = (valor) => {
                const digitos = (valor || '').replace(/\D/g, '').slice(0, 11);
                if (!digitos) return '';
                if (digitos.length <= 2) return `(${digitos}`;
                if (digitos.length <= 7) return `(${digitos.slice(0, 2)}) ${digitos.slice(2)}`;
                return `(${digitos.slice(0, 2)}) ${digitos.slice(2, 7)}-${digitos.slice(7)}`;
            };

            input.value = formatarCelular(input.value);
            input.addEventListener('input', function () {
                this.value = formatarCelular(this.value);
            });
        })();
    </script>
}
