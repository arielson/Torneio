@model IEnumerable<MembroDto>
@{
    var slug    = Context.GetRouteData().Values["slug"]?.ToString();
    var anoId   = Context.GetRouteData().Values["anoId"]?.ToString();
    var ano     = (AnoTorneioDto)ViewBag.Ano;
    var torneio = (TorneioDto)ViewBag.Torneio;
    var label   = torneio?.LabelMembro ?? "Membro";
    ViewData["Title"] = $"{label}s — {ano.Ano}";
    var lista = Model.ToList();
}

<div class="page-header">
    <div class="page-header-left">
        <h1>@label&#x73; — @ano.Ano</h1>
    </div>
    <div class="page-header-actions">
        <a href="/@slug/membros/@anoId/criar" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Novo @label
        </a>
    </div>
</div>
<a href="/@slug/admin" class="back-link">
    <i class="bi bi-arrow-left"></i> Painel
</a>

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-person me-2"></i>@label&#x73; cadastrados</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">
            Nenhum @label.ToLower() cadastrado. <a href="/@slug/membros/@anoId/criar">Criar o primeiro</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in lista)
                    {
                        <tr>
                            <td class="fw-semibold">@m.Nome</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/@slug/membros/@anoId/@m.Id/editar" class="btn btn-sm btn-outline-secondary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-controller="Membro" asp-action="Remover" asp-route-slug="@slug" asp-route-anoId="@anoId" asp-route-id="@m.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remover @m.Nome?')" title="Remover">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
