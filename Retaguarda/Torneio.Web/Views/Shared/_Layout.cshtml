@using System.Security.Claims
@using Torneio.Application.DTOs.Torneio
@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(Configuration["Branding:ApplicationName"] ?? "Torneio")</title>
    <link rel="icon" type="image/png" href="~/favicon.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @{
        var torneioTheme = ViewBag.Torneio as TorneioDto;
        var corPrimariaTheme = torneioTheme?.CorPrimaria;
    }
    @if (!string.IsNullOrEmpty(corPrimariaTheme))
    {
        <style>:root { --brand: @corPrimariaTheme; --brand-dark: @corPrimariaTheme; }</style>
    }
</head>
@{
    var isAuthPage  = ViewData["IsAuthPage"] as bool? == true;
    var perfil      = User.FindFirst("perfil")?.Value;
    var isAdmin     = perfil == "AdminGeral" || perfil == "AdminTorneio";
    var isAdminGeral = perfil == "AdminGeral";
    var isMembro = perfil == "Membro";
    var slug        = Context.GetRouteData()?.Values["slug"]?.ToString();
    var nomeUsuario = User.Identity?.Name;
    var torneioNav  = ViewBag.Torneio as TorneioDto;
    var effectiveSlug = slug ?? torneioNav?.Slug;
    var labelItem   = torneioNav?.LabelItem ?? "Item";
    var labelCaptura = torneioNav?.LabelCaptura ?? "Captura";
    var exibirSorteio = !string.Equals(torneioNav?.ModoSorteio, "Nenhum", StringComparison.OrdinalIgnoreCase);
    var exibirFinanceiro = torneioNav?.ExibirModuloFinanceiro ?? true;
    var applicationName = Configuration["Branding:ApplicationName"] ?? "Torneio";
    var slugLogado = User.FindFirst("slug")?.Value;
    var isPublicPage = Context.Request.Path.Value?.TrimEnd('/').Equals($"/{slug}", StringComparison.OrdinalIgnoreCase) ?? false;
    var estaEmOutroTorneio = !string.IsNullOrWhiteSpace(slugLogado)
        && !string.IsNullOrEmpty(slug)
        && !string.Equals(slugLogado, slug, StringComparison.OrdinalIgnoreCase);
    var usarLayoutAdmin = isAdmin && (isAdminGeral || !string.IsNullOrEmpty(effectiveSlug)) && !(estaEmOutroTorneio && isPublicPage);

    bool IsActive(string path) =>
        (Context.Request.Path.Value ?? "").StartsWith(path, StringComparison.OrdinalIgnoreCase);
    bool IsExact(string path) =>
        string.Equals(Context.Request.Path.Value, path, StringComparison.OrdinalIgnoreCase);
    bool IsEquipeSectionActive(string slugValue)
    {
        var currentPath = Context.Request.Path.Value ?? "";
        var reorganizacaoPath = $"/{slugValue}/equipes/reorganizacao-emergencial";
        if (currentPath.StartsWith(reorganizacaoPath, StringComparison.OrdinalIgnoreCase))
            return false;

        return currentPath.StartsWith($"/{slugValue}/equipes", StringComparison.OrdinalIgnoreCase);
    }
}
@if (isAuthPage)
{
    <body class="auth-page">
        @RenderBody()
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
}
else if (usarLayoutAdmin)
{
    <body class="admin-layout">
        <div id="layout-wrapper">

            <!-- ── Sidebar ─────────────────────────────────────────────── -->
            <nav id="sidebar">
                @if (!string.IsNullOrEmpty(effectiveSlug))
                {
                    <!-- Tournament context brand -->
                    <a class="sidebar-brand" href="/@effectiveSlug/admin">
                        <i class="bi bi-trophy-fill"></i>
                        <span class="text-truncate">@(torneioNav?.NomeTorneio ?? effectiveSlug)</span>
                    </a>
                    <ul class="sidebar-nav">
                        @if (isAdminGeral)
                        {
                            <li>
                                <a class="nav-link" href="/admin">
                                    <i class="bi bi-arrow-left-circle"></i> Início
                                </a>
                            </li>
                            <hr class="sidebar-divider" />
                        }
                        <li class="sidebar-section-label">@applicationName</li>
                        <li>
                            <a class="nav-link @(IsExact($"/{effectiveSlug}/admin") ? "active" : "")" href="/@effectiveSlug/admin">
                                <i class="bi bi-house"></i> Painel
                            </a>
                        </li>
                        <li>
                            <a class="nav-link @(IsActive($"/{effectiveSlug}/admin/editar") ? "active" : "")" href="/@effectiveSlug/admin/editar">
                                <i class="bi bi-sliders"></i> Dados do Torneio
                            </a>
                        </li>
                        <hr class="sidebar-divider" />
                        <li class="sidebar-section-label">Cadastros</li>
                        <li>
                            <a class="nav-link @(IsEquipeSectionActive(effectiveSlug) ? "active" : "")" href="/@effectiveSlug/equipes">
                                <i class="bi bi-people"></i> @(torneioNav?.LabelEquipePlural ?? "Equipes")
                            </a>
                        </li>
                        <li>
                            <a class="nav-link @(IsActive($"/{effectiveSlug}/fiscais") ? "active" : "")" href="/@effectiveSlug/fiscais">
                                <i class="bi bi-person-badge"></i> @(torneioNav?.LabelSupervisorPlural ?? "Fiscais")
                            </a>
                        </li>
                        <li>
                            <a class="nav-link @(IsActive($"/{effectiveSlug}/membros") ? "active" : "")" href="/@effectiveSlug/membros">
                                <i class="bi bi-person"></i> @(torneioNav?.LabelMembroPlural ?? "Membros")
                            </a>
                        </li>
                        @if (string.Equals(torneioNav?.ModoSorteio, "GrupoEquipe", StringComparison.OrdinalIgnoreCase))
                        {
                            <li>
                                <a class="nav-link @(IsActive($"/{effectiveSlug}/grupos") ? "active" : "")" href="/@effectiveSlug/grupos">
                                    <i class="bi bi-people-fill"></i> Grupos
                                </a>
                            </li>
                        }
                        <li>
                            <a class="nav-link @(IsActive($"/{effectiveSlug}/itens") ? "active" : "")" href="/@effectiveSlug/itens">
                                <i class="bi bi-collection"></i> @(torneioNav?.LabelItemPlural ?? "Itens")
                            </a>
                        </li>
                        <li>
                            <a class="nav-link @(IsActive($"/{effectiveSlug}/patrocinadores") ? "active" : "")" href="/@effectiveSlug/patrocinadores">
                                <i class="bi bi-megaphone"></i> Patrocinadores
                            </a>
                        </li>
                        @if (exibirFinanceiro)
                        {
                            <hr class="sidebar-divider" />
                            <li class="sidebar-section-label">Financeiro</li>
                            <li>
                                <a class="nav-link @(IsExact($"/{effectiveSlug}/financeiro") ? "active" : "")" href="/@effectiveSlug/financeiro">
                                    <i class="bi bi-graph-up"></i> Visão geral
                                </a>
                            </li>
                            <li>
                                <a class="nav-link @(IsActive($"/{effectiveSlug}/financeiro/configuracao") ? "active" : "")" href="/@effectiveSlug/financeiro/configuracao">
                                    <i class="bi bi-sliders"></i> Configuração
                                </a>
                            </li>
                            <li>
                                <a class="nav-link @(IsActive($"/{effectiveSlug}/financeiro/cobrancas") ? "active" : "")" href="/@effectiveSlug/financeiro/cobrancas">
                                    <i class="bi bi-receipt-cutoff"></i> Cobranças
                                </a>
                            </li>
                            <li>
                                <a class="nav-link @(IsActive($"/{effectiveSlug}/financeiro/custos") ? "active" : "")" href="/@effectiveSlug/financeiro/custos">
                                    <i class="bi bi-cash-stack"></i> Custos
                                </a>
                            </li>
                            <li>
                                <a class="nav-link @(IsActive($"/{effectiveSlug}/financeiro/extras") ? "active" : "")" href="/@effectiveSlug/financeiro/extras">
                                    <i class="bi bi-bag"></i> Produtos extras
                                </a>
                            </li>
                            <li>
                                <a class="nav-link @(IsActive($"/{effectiveSlug}/financeiro/doacoes") ? "active" : "")" href="/@effectiveSlug/financeiro/doacoes">
                                    <i class="bi bi-gift"></i> Doações
                                </a>
                            </li>
                            <li>
                                <a class="nav-link @(IsActive($"/{effectiveSlug}/financeiro/checklist") ? "active" : "")" href="/@effectiveSlug/financeiro/checklist">
                                    <i class="bi bi-list-check"></i> Checklist
                                </a>
                            </li>
                            <li>
                                <a class="nav-link @(IsActive($"/{effectiveSlug}/financeiro/relatorios") ? "active" : "")" href="/@effectiveSlug/financeiro/relatorios">
                                    <i class="bi bi-graph-up-arrow"></i> Relatórios
                                </a>
                            </li>
                        }
                        <hr class="sidebar-divider" />
                        <li class="sidebar-section-label">Operações</li>
                        <li>
                            <a class="nav-link @(IsActive($"/{effectiveSlug}/capturas") ? "active" : "")" href="/@effectiveSlug/capturas">
                                <i class="bi bi-camera"></i> @(torneioNav?.LabelCapturaPlural ?? "Capturas")
                            </a>
                        </li>
                        @if (exibirSorteio)
                        {
                            <li>
                                <a class="nav-link @(IsActive($"/{effectiveSlug}/sorteio") ? "active" : "")" href="/@effectiveSlug/sorteio">
                                    <i class="bi bi-shuffle"></i> Sorteio
                                </a>
                            </li>
                        }
                        <li>
                            <a class="nav-link @(IsActive($"/{effectiveSlug}/premios") ? "active" : "")" href="/@effectiveSlug/premios">
                                <i class="bi bi-trophy"></i> Prêmios
                            </a>
                        </li>
                        <li>
                            <a class="nav-link @(IsActive($"/{effectiveSlug}/relatorios") ? "active" : "")" href="/@effectiveSlug/relatorios">
                                <i class="bi bi-file-earmark-bar-graph"></i> Relatórios
                            </a>
                        </li>
                        @if (exibirSorteio)
                        {
                            <li>
                                <a class="nav-link @(IsActive($"/{effectiveSlug}/equipes/reorganizacao-emergencial") ? "active" : "")" href="/@effectiveSlug/equipes/reorganizacao-emergencial">
                                    <i class="bi bi-exclamation-triangle"></i> Reorganização Emergencial
                                </a>
                            </li>
                        }
                        @if (isAdminGeral && torneioNav != null)
                        {
                            <hr class="sidebar-divider" />
                            <li class="sidebar-section-label">Acesso</li>
                            <li>
                                <a class="nav-link @(IsActive($"/admin/torneios/{torneioNav.Id}/admins") ? "active" : "")"
                                   href="/admin/torneios/@torneioNav.Id/admins">
                                    <i class="bi bi-people"></i> Admins do Torneio
                                </a>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <!-- Platform context brand -->
                    <a class="sidebar-brand" href="/admin">
                        <i class="bi bi-grid-3x3-gap-fill"></i>
                        <span>@applicationName</span>
                    </a>
                    <ul class="sidebar-nav">
                        <li class="sidebar-section-label">Geral</li>
                        <li>
                            <a class="nav-link @(IsExact("/admin") ? "active" : "")" href="/admin">
                                <i class="bi bi-speedometer2"></i> Painel
                            </a>
                        </li>
                        <hr class="sidebar-divider" />
                        <li class="sidebar-section-label">Torneios</li>
                        <li>
                            <a class="nav-link @(IsActive("/admin/torneios/criar") ? "active" : "")"
                               href="/admin/torneios/criar">
                                <i class="bi bi-plus-circle"></i> Novo Torneio
                            </a>
                        </li>
                        <li>
                            <a class="nav-link @(IsActive("/admin/banners") ? "active" : "")" href="/admin/banners">
                                <i class="bi bi-images"></i> Banners
                            </a>
                        </li>
                        <li>
                            <a class="nav-link @(IsActive("/admin/especies") ? "active" : "")" href="/admin/especies">
                                <i class="bi bi-collection"></i> Espécies de Peixe
                            </a>
                        </li>
                        <hr class="sidebar-divider" />
                        <li class="sidebar-section-label">Acesso</li>
                        <li>
                            <a class="nav-link @(IsActive("/admin/admins") ? "active" : "")" href="/admin/admins">
                                <i class="bi bi-shield-check"></i> Admins Gerais
                            </a>
                        </li>
                        <hr class="sidebar-divider" />
                        <li class="sidebar-section-label">Auditoria</li>
                        <li>
                            <a class="nav-link @(IsActive("/admin/logs") ? "active" : "")" href="/admin/logs">
                                <i class="bi bi-journal-text"></i> Logs
                            </a>
                        </li>
                    </ul>
                }
            </nav>

            <!-- ── Page content ──────────────────────────────────────────── -->
            <div id="page-content">

                <!-- Top bar -->
                <div id="topbar">
                    <button id="sidebarToggle" title="Menu">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="topbar-user">
                        <span class="topbar-user-name d-none d-sm-inline">@nomeUsuario</span>
                        <span class="topbar-user-role">@perfil</span>
                        <form method="post" action="/logout" class="d-inline m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-box-arrow-right"></i>
                                <span class="d-none d-sm-inline ms-1">Sair</span>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Main content -->
                <main class="page-main">
                    @if (TempData["Sucesso"] is string sucesso)
                    {
                        <div class="flash-area">
                            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
                                <i class="bi bi-check-circle-fill"></i>
                                @sucesso
                                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                            </div>
                        </div>
                    }
                    @if (TempData["Erro"] is string erro)
                    {
                        <div class="flash-area">
                            <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                @erro
                                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                            </div>
                        </div>
                    }
                    @RenderBody()
                </main>

                <footer class="page-footer">
                    <span>&copy; @DateTime.Now.Year - @applicationName</span>
                    <span class="mx-2 text-muted">|</span>
                    <a href="/politica-de-privacidade">Política de Privacidade</a>
                    <span class="mx-2 text-muted">|</span>
                    <a href="/suporte">Suporte</a>
                </footer>
            </div>

        </div>
        <div id="sidebar-overlay"></div>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
}
else
{
    <!-- Public layout -->
    <body>
        <nav class="navbar navbar-expand-sm navbar-dark public-navbar border-bottom mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">
                    <i class="bi bi-trophy-fill me-2" style="color:#3b82f6"></i>@applicationName
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navPublic">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="navPublic">
                    <ul class="navbar-nav ms-auto">
                        @if (estaEmOutroTorneio)
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" href="/@slugLogado/admin">
                                    <i class="bi bi-arrow-left-circle me-1"></i>Voltar para @slugLogado
                                </a>
                            </li>
                        }
                        else if (!string.IsNullOrEmpty(slug))
                        {
                            @if (isMembro)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/@slug/minhas-cobrancas">
                                        <i class="bi bi-receipt me-1"></i>Minhas cobranças
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <form method="post" action="/logout" class="d-inline m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="nav-link btn btn-link">
                                            <i class="bi bi-box-arrow-right me-1"></i>Sair
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/@slug/login">
                                        <i class="bi bi-box-arrow-in-right me-1"></i>Entrar
                                    </a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Entrar
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
        <div class="container pb-5">
            @if (TempData["Sucesso"] is string sucesso)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @sucesso
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Erro"] is string erro)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @erro
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            <main role="main">@RenderBody()</main>
        </div>
        <footer class="border-top py-3 mt-4">
            <div class="container">
                <small class="text-muted">
                    &copy; @DateTime.Now.Year - @applicationName
                    <span class="mx-2">|</span>
                    <a href="/politica-de-privacidade">Política de Privacidade</a>
                    <span class="mx-2">|</span>
                    <a href="/suporte">Suporte</a>
                </small>
            </div>
        </footer>
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
}
</html>

