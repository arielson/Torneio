@model Torneio.Web.Models.MaioresCapturasFiltroViewModel
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    var torneio = (TorneioDto)ViewBag.Torneio;
    ViewData["Title"] = "Relatorio das Maiores Capturas";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Relatorio das Maiores Capturas</h1>
    </div>
</div>
<a href="/@slug/relatorios" class="back-link">
    <i class="bi bi-arrow-left"></i> Relatorios
</a>

@if (TempData["Erro"] is string erro && !string.IsNullOrWhiteSpace(erro))
{
    <div class="alert alert-danger d-flex gap-2 align-items-center">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>@erro</span>
    </div>
}

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-rulers me-2"></i>Ranking por medida</h5>
    </div>
    <div class="card-body-pad">
        <p class="text-muted small mb-3">
            Gere um PDF com as maiores capturas validas do torneio, ordenadas pela medida registrada.
        </p>

        <form method="get" action="/@slug/relatorios/maiores-capturas/download" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label" for="quantidade">Quantidade</label>
                <input id="quantidade"
                       name="quantidade"
                       type="number"
                       min="1"
                       max="999"
                       value="@Model.Quantidade"
                       class="form-control"
                       required />
                <div class="form-text">Informe de 1 a 999 maiores capturas.</div>
            </div>
            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-file-earmark-pdf me-1"></i>Emitir relatorio
                </button>
            </div>
        </form>
    </div>
</div>
