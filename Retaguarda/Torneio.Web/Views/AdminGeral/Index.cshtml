@model IEnumerable<TorneioDto>
@{
    ViewData["Title"] = "Painel Admin Geral";
    var lista = Model.ToList();
    var total = lista.Count;
    var ativos = lista.Count(t => t.Ativo);
    var inativos = total - ativos;
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Painel Geral</h1>
    </div>
    <div class="page-header-actions">
        <a asp-controller="AdminGeral" asp-action="CriarTorneio" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Novo Torneio
        </a>
        <a asp-controller="AdminGeral" asp-action="Admins" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-shield-check me-1"></i>Admins Gerais
        </a>
        <a asp-controller="EspeciePeixe" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-collection me-1"></i>Espécies de Peixe
        </a>
        <a asp-controller="Logs" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-journal-text me-1"></i>Logs
        </a>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-trophy"></i></div>
            <div>
                <div class="stat-value">@total</div>
                <div class="stat-label">Torneios cadastrados</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-check-circle"></i></div>
            <div>
                <div class="stat-value">@ativos</div>
                <div class="stat-label">Torneios ativos</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-icon gray"><i class="bi bi-pause-circle"></i></div>
            <div>
                <div class="stat-value">@inativos</div>
                <div class="stat-label">Torneios inativos</div>
            </div>
        </div>
    </div>
</div>

<!-- Torneios table -->
<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-trophy me-2"></i>Torneios</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">
            Nenhum torneio cadastrado. <a asp-action="CriarTorneio">Criar o primeiro</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Slug</th>
                        <th>Status</th>
                        <th>Modo Sorteio</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in lista)
                    {
                        <tr>
                            <td class="fw-semibold">@t.NomeTorneio</td>
                            <td><code class="text-muted small">@t.Slug</code></td>
                            <td>
                                @if (t.Ativo)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                                        <i class="bi bi-circle-fill me-1" style="font-size:.5rem;vertical-align:middle"></i>Ativo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">
                                        <i class="bi bi-circle me-1" style="font-size:.5rem;vertical-align:middle"></i>Inativo
                                    </span>
                                }
                            </td>
                            <td class="text-muted small">@t.ModoSorteio</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end flex-wrap">
                                    <a href="/@t.Slug/admin" class="btn btn-sm btn-outline-primary" title="Painel do Torneio">
                                        <i class="bi bi-box-arrow-in-right"></i>
                                    </a>
                                    @if (!string.Equals(t.ModoSorteio, "Nenhum", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a href="/@t.Slug/equipes/reorganizacao-emergencial" class="btn btn-sm btn-outline-danger" title="Reorganizacao Emergencial">
                                            <i class="bi bi-exclamation-triangle"></i>
                                        </a>
                                    }
                                    <a asp-action="EditarTorneio" asp-route-id="@t.Id" class="btn btn-sm btn-outline-secondary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="AdminsTorneio" asp-route-torneioId="@t.Id" class="btn btn-sm btn-outline-secondary" title="Admins">
                                        <i class="bi bi-people"></i>
                                    </a>
                                    @if (t.Ativo)
                                    {
                                        <form asp-action="Desativar" asp-route-id="@t.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-danger" title="Desativar"
                                                    onclick="return confirm('Desativar @t.NomeTorneio?')">
                                                <i class="bi bi-pause-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Ativar" asp-route-id="@t.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-success" title="Ativar">
                                                <i class="bi bi-play-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    <form asp-action="Excluir" asp-route-id="@t.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-danger" title="Excluir permanentemente"
                                                onclick="return confirm('ATENÇÃO: isso excluirá o torneio \'@t.NomeTorneio\' e TODOS os seus dados (equipes, membros, fiscais, capturas, sorteios e prêmios) de forma irreversível.\n\nTem certeza?')">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
