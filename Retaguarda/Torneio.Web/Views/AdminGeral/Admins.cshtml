@model IEnumerable<AdminGeralDto>
@{
    ViewData["Title"] = "Admins Gerais";
    var lista = Model.ToList();
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Admins Gerais</h1>
    </div>
    <div class="page-header-actions">
        <a asp-action="CriarAdmin" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Novo Admin
        </a>
    </div>
</div>
<a asp-action="Index" class="back-link">
    <i class="bi bi-arrow-left"></i> Painel
</a>

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-shield-check me-2"></i>Administradores da Plataforma</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">Nenhum admin cadastrado.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Usuário</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in lista)
                    {
                        <tr>
                            <td class="fw-semibold">@a.Nome</td>
                            <td><code class="text-muted small">@a.Usuario</code></td>
                            <td class="text-end">
                                <form asp-action="RemoverAdmin" asp-route-id="@a.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Remover @a.Nome?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
