@model CriarAdminTorneioDto
@{
    ViewData["Title"] = "Novo Admin do Torneio";
    var torneio = (TorneioDto)ViewBag.Torneio;
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Novo Admin — @torneio.NomeTorneio</h1>
    </div>
</div>
<a asp-action="AdminsTorneio" asp-route-torneioId="@torneio.Id" class="back-link">
    <i class="bi bi-arrow-left"></i> Admins do Torneio
</a>

<div class="form-card">
    <form asp-action="CriarAdminTorneio" asp-route-torneioId="@torneio.Id" method="post">
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }
        <div class="form-section-title">Dados do Administrador</div>
        <div class="mb-3">
            <label asp-for="Nome" class="form-label">Nome</label>
            <input asp-for="Nome" class="form-control" placeholder="Nome completo" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Usuario" class="form-label">Usuário</label>
            <input asp-for="Usuario" class="form-control" placeholder="nome de login" autocomplete="username" />
            <span asp-validation-for="Usuario" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Senha" class="form-label">Senha</label>
            <input asp-for="Senha" class="form-control" type="password" autocomplete="new-password" />
            <span asp-validation-for="Senha" class="text-danger small"></span>
        </div>
        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Criar Admin
            </button>
            <a asp-action="AdminsTorneio" asp-route-torneioId="@torneio.Id" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
