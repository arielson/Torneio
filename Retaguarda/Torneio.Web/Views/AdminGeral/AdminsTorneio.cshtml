@model IEnumerable<AdminTorneioDto>
@{
    ViewData["Title"] = "Admins do Torneio";
    var torneio = (TorneioDto)ViewBag.Torneio;
    var lista = Model.ToList();
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Admins - @torneio.NomeTorneio</h1>
    </div>
    <div class="page-header-actions">
        <a asp-action="CriarAdminTorneio" asp-route-torneioId="@torneio.Id" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Novo Admin
        </a>
    </div>
</div>
<a asp-action="Index" class="back-link">
    <i class="bi bi-arrow-left"></i> Painel
</a>

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-people me-2"></i>Administradores do Torneio</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">Nenhum admin cadastrado para este torneio.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Usuario</th>
                        <th>Ultimo acesso</th>
                        <th>Troca de senha</th>
                        <th>Status</th>
                        <th class="text-end">Acoes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in lista)
                    {
                        <tr>
                            <td class="fw-semibold">@a.Nome</td>
                            <td><code class="text-muted small">@a.Usuario</code></td>
                            <td>
                                @if (a.UltimoAcessoEm.HasValue)
                                {
                                    <span>@a.UltimoAcessoEm.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                }
                                else
                                {
                                    <span class="text-muted">Nunca acessou</span>
                                }
                            </td>
                            <td>
                                @if (a.SenhaAlteradaEm.HasValue)
                                {
                                    <span>@a.SenhaAlteradaEm.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                }
                                else
                                {
                                    <span class="text-muted">Sem registro</span>
                                }
                            </td>
                            <td>
                                @if (a.DeveAlterarSenha)
                                {
                                    <span class="badge bg-warning text-dark">Troca pendente</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="RedefinirSenhaAdminTorneio"
                                   asp-route-torneioId="@torneio.Id"
                                   asp-route-id="@a.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   title="Redefinir senha">
                                    <i class="bi bi-key"></i>
                                </a>
                                <form asp-action="RemoverAdminTorneio" asp-route-torneioId="@torneio.Id" asp-route-id="@a.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Remover @a.Nome?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
