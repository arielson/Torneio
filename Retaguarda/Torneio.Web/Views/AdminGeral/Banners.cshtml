@model IEnumerable<BannerDto>
@using Torneio.Application.DTOs.Banner
@{
    ViewData["Title"] = "Banners";
    var lista = Model.ToList();
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Banners</h1>
    </div>
    <div class="page-header-actions">
        <a asp-action="CriarBanner" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Novo Banner
        </a>
    </div>
</div>
<a asp-action="Index" class="back-link">
    <i class="bi bi-arrow-left"></i> Painel
</a>

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-images me-2"></i>Banners cadastrados</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">
            Nenhum banner cadastrado. <a asp-action="CriarBanner">Criar o primeiro</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Imagem</th>
                        <th>Torneio</th>
                        <th>Destino</th>
                        <th>Ordem</th>
                        <th>Status</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in lista.OrderBy(x => x.Ordem))
                    {
                        var (icone, detalhe) = b.TipoDestino switch
                        {
                            "Torneio"   => ("bi-trophy",    b.TorneioNome),
                            "Site"      => ("bi-globe2",    b.Destino ?? ""),
                            "WhatsApp"  => ("bi-whatsapp",  b.Destino ?? ""),
                            "Instagram" => ("bi-instagram", "@" + b.Destino),
                            "Email"     => ("bi-envelope",  b.Destino ?? ""),
                            _           => ("bi-image",     "Somente imagem"),
                        };
                        <tr>
                            <td>
                                <img src="@b.ImagemUrl" alt="Banner" style="max-height:60px;max-width:120px;border-radius:4px;object-fit:cover;" />
                            </td>
                            <td>
                                <span class="fw-semibold">@b.TorneioNome</span><br />
                                <code class="text-muted small">@b.TorneioSlug</code>
                            </td>
                            <td>
                                <i class="bi @icone me-1"></i><small>@b.TipoDestino</small>
                                @if (!string.IsNullOrEmpty(detalhe))
                                {
                                    <br /><small class="text-muted">@detalhe</small>
                                }
                            </td>
                            <td>@b.Ordem</td>
                            <td>
                                @if (b.Ativo)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Inativo</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end flex-wrap">
                                    @if (b.Ativo)
                                    {
                                        <form asp-action="DesativarBanner" asp-route-id="@b.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-secondary" title="Desativar">
                                                <i class="bi bi-pause-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="AtivarBanner" asp-route-id="@b.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-success" title="Ativar">
                                                <i class="bi bi-play-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    <form asp-action="ExcluirBanner" asp-route-id="@b.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" title="Remover"
                                                onclick="return confirm('Remover este banner?')">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
