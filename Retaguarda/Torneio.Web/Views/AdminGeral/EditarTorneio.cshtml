@model AtualizarTorneioDto
@{
    ViewData["Title"] = "Editar Torneio";
    var torneioId    = (Guid)ViewBag.TorneioId;
    var modosSorteio = (ModoSorteio[])ViewBag.ModosSorteio;
    var tipoTorneio  = ViewBag.TipoTorneio is TipoTorneio t ? t : TipoTorneio.Pesca;
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Editar Torneio</h1>
    </div>
</div>
<a asp-action="Index" class="back-link">
    <i class="bi bi-arrow-left"></i> Voltar ao painel
</a>

<div class="form-card">
    <form asp-action="EditarTorneio" asp-route-id="@torneioId" method="post" enctype="multipart/form-data">
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }

        <div class="form-section-title">Tipo</div>
        <div class="mb-3">
            <label class="form-label">Tipo de Torneio</label>
            <input type="text" class="form-control bg-light" value="@tipoTorneio" readonly />
            <div class="form-text"><i class="bi bi-info-circle me-1"></i>O tipo não pode ser alterado após a criação.</div>
        </div>

        <div class="form-section-title">Identificação</div>
        <div class="mb-3">
            <label asp-for="NomeTorneio" class="form-label">Nome do Torneio</label>
            <input asp-for="NomeTorneio" class="form-control" />
            <span asp-validation-for="NomeTorneio" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Logo <small class="text-muted fw-normal">(opcional)</small></label>
            @if (!string.IsNullOrEmpty(Model.LogoUrl))
            {
                <div class="mb-2 d-flex align-items-center gap-3">
                    <img src="@Model.LogoUrl" alt="Logo atual"
                         style="max-height:80px;max-width:160px;border-radius:6px;border:1px solid #dee2e6;object-fit:contain;" />
                    <span class="text-muted small">Logo atual. Envie um novo arquivo para substituir.</span>
                </div>
            }
            <input type="file" name="logoArquivo" class="form-control" accept="image/*" />
            <div class="form-text">Ou mantenha / altere a URL externa abaixo — o upload tem prioridade.</div>
        </div>
        <div class="mb-3">
            <label asp-for="LogoUrl" class="form-label">URL do Logo <small class="text-muted fw-normal">(opcional)</small></label>
            <input asp-for="LogoUrl" class="form-control" placeholder="https://..." />
        </div>

        <div class="form-section-title">Terminologia</div>
        <div class="form-text text-muted mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Defina como cada conceito é chamado neste torneio, no singular e no plural.
        </div>

        <div class="row g-3 mb-2">
            <div class="col-md-6">
                <label asp-for="LabelEquipe" class="form-label">Equipe / Grupo <small class="text-muted">(singular)</small></label>
                <input asp-for="LabelEquipe" class="form-control" placeholder="ex: Embarcação, Equipe, Grupo" />
                <span asp-validation-for="LabelEquipe" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LabelEquipePlural" class="form-label">Equipe / Grupo <small class="text-muted">(plural)</small></label>
                <input asp-for="LabelEquipePlural" class="form-control" placeholder="ex: Embarcações, Equipes, Grupos" />
                <span asp-validation-for="LabelEquipePlural" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LabelMembro" class="form-label">Membro <small class="text-muted">(singular)</small></label>
                <input asp-for="LabelMembro" class="form-control" placeholder="ex: Pescador, Atleta, Participante" />
                <span asp-validation-for="LabelMembro" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LabelMembroPlural" class="form-label">Membro <small class="text-muted">(plural)</small></label>
                <input asp-for="LabelMembroPlural" class="form-control" placeholder="ex: Pescadores, Atletas, Participantes" />
                <span asp-validation-for="LabelMembroPlural" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LabelSupervisor" class="form-label">Supervisor <small class="text-muted">(singular)</small></label>
                <input asp-for="LabelSupervisor" class="form-control" placeholder="ex: Fiscal, Monitor, Juiz" />
                <span asp-validation-for="LabelSupervisor" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LabelSupervisorPlural" class="form-label">Supervisor <small class="text-muted">(plural)</small></label>
                <input asp-for="LabelSupervisorPlural" class="form-control" placeholder="ex: Fiscais, Monitores, Juízes" />
                <span asp-validation-for="LabelSupervisorPlural" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LabelItem" class="form-label">Item <small class="text-muted">(singular)</small></label>
                <input asp-for="LabelItem" class="form-control" placeholder="ex: Peixe, Espécie, Item" />
                <span asp-validation-for="LabelItem" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LabelItemPlural" class="form-label">Item <small class="text-muted">(plural)</small></label>
                <input asp-for="LabelItemPlural" class="form-control" placeholder="ex: Peixes, Espécies, Itens" />
                <span asp-validation-for="LabelItemPlural" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LabelCaptura" class="form-label">Captura <small class="text-muted">(singular)</small></label>
                <input asp-for="LabelCaptura" class="form-control" placeholder="ex: Captura, Pesca, Registro" />
                <span asp-validation-for="LabelCaptura" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LabelCapturaPlural" class="form-label">Captura <small class="text-muted">(plural)</small></label>
                <input asp-for="LabelCapturaPlural" class="form-control" placeholder="ex: Capturas, Pescas, Registros" />
                <span asp-validation-for="LabelCapturaPlural" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="MedidaCaptura" class="form-label">Unidade de Medida</label>
                <input asp-for="MedidaCaptura" class="form-control" placeholder="ex: cm, kg, m" />
                <span asp-validation-for="MedidaCaptura" class="text-danger small"></span>
            </div>
        </div>

        <div class="form-section-title">Regras</div>
        <div class="mb-3">
            <label asp-for="ModoSorteio" class="form-label">Modo de Sorteio</label>
            <select asp-for="ModoSorteio" class="form-select">
                @foreach (var m in modosSorteio)
                {
                    <option value="@m" selected="@(Model.ModoSorteio == m)">@m</option>
                }
            </select>
            <span asp-validation-for="ModoSorteio" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="QtdGanhadores" class="form-label">Quantidade de Ganhadores</label>
            <input asp-for="QtdGanhadores" class="form-control" type="number" min="1" max="100" />
            <div class="form-text">Número de posições premiadas (1º, 2º, 3º…)</div>
            <span asp-validation-for="QtdGanhadores" class="text-danger small"></span>
        </div>
        <div class="form-check mb-2">
            <input asp-for="UsarFatorMultiplicador" class="form-check-input" type="checkbox" />
            <label asp-for="UsarFatorMultiplicador" class="form-check-label">Usar Fator Multiplicador</label>
        </div>
        <div class="form-check mb-3">
            <input asp-for="PermitirCapturaOffline" class="form-check-input" type="checkbox" />
            <label asp-for="PermitirCapturaOffline" class="form-check-label">Permitir Captura Offline</label>
        </div>
        <div class="form-check mb-3">
            <input asp-for="ExibirModuloFinanceiro" class="form-check-input" type="checkbox" />
            <label asp-for="ExibirModuloFinanceiro" class="form-check-label">Exibir Módulo Financeiro</label>
        </div>
        <div class="form-check mb-3">
            <input asp-for="PermitirRegistroPublicoMembro" class="form-check-input" type="checkbox" />
            <label asp-for="PermitirRegistroPublicoMembro" class="form-check-label">Permitir cadastro público de pescador com SMS</label>
        </div>

        <div class="form-section-title">Premiação</div>
        <div class="form-text text-muted mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Selecione a quem se destina o ranking de ganhadores.
        </div>
        <div class="form-check mb-2">
            <input asp-for="PremiacaoPorEquipe" class="form-check-input" type="checkbox" />
            <label asp-for="PremiacaoPorEquipe" class="form-check-label">Premiar por @Model.LabelEquipePlural <small class="text-muted">(ranking de equipes)</small></label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="PremiacaoPorMembro" class="form-check-input" type="checkbox" />
            <label asp-for="PremiacaoPorMembro" class="form-check-label">Premiar por @Model.LabelMembroPlural <small class="text-muted">(ranking individual)</small></label>
        </div>
        <div class="form-check mb-3">
            <input asp-for="ApenasMaiorCapturaPorPescador" class="form-check-input" type="checkbox" />
            <label asp-for="ApenasMaiorCapturaPorPescador" class="form-check-label">
                Apenas a maior captura por @Model.LabelMembro.ToLower() no ranking
                <small class="text-muted d-block">Quando ativado, cada @Model.LabelMembro.ToLower() contribui somente com sua melhor captura. Uma nova captura maior substitui a anterior.</small>
            </label>
        </div>

        <div class="form-section-title">Tema Visual</div>
        <div class="form-text text-muted mb-3">
            <i class="bi bi-palette me-1"></i>
            Opcional — deixe em branco para usar as cores padrão da plataforma.
        </div>
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="CorPrimaria" class="form-label">Cor Primária</label>
                <div class="input-group">
                    <input asp-for="CorPrimaria" type="color" class="form-control form-control-color"
                           value="@(Model.CorPrimaria ?? "#1976D2")" title="Cor primária" style="max-width:56px;"
                           oninput="document.getElementById('CorPrimariaHex').value=this.value" />
                    <input id="CorPrimariaHex" class="form-control" placeholder="#1976D2" maxlength="7"
                           oninput="document.getElementById('CorPrimaria').value=this.value"
                           value="@(Model.CorPrimaria ?? "")" />
                </div>
                <span asp-validation-for="CorPrimaria" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Salvar Alterações
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
