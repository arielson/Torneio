@model IEnumerable<PatrocinadorDto>
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    ViewData["Title"] = "Patrocinadores";
    var lista = Model.ToList();
    var storageBase = ViewBag.StorageBaseUrl as string ?? "";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Patrocinadores</h1>
    </div>
    <div class="page-header-actions">
        <a href="/@slug/patrocinadores/criar" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Novo patrocinador
        </a>
    </div>
</div>
<a href="/@slug/admin" class="back-link">
    <i class="bi bi-arrow-left"></i> Painel
</a>

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-megaphone me-2"></i>Patrocinadores cadastrados</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">
            Nenhum patrocinador cadastrado. <a href="/@slug/patrocinadores/criar">Criar o primeiro</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="width:48px"></th>
                        <th>Nome</th>
                        <th>Instagram</th>
                        <th>Facebook</th>
                        <th>Site</th>
                        <th>Zap</th>
                        <th class="text-end">Acoes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var patrocinador in lista)
                    {
                        var fotoPatrocinador = string.IsNullOrWhiteSpace(patrocinador.FotoUrl) ? null
                            : (patrocinador.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? patrocinador.FotoUrl : $"{storageBase}/{patrocinador.FotoUrl.TrimStart('/')}");
                        <tr>
                            <td>
                                @if (fotoPatrocinador != null)
                                {
                                    <img src="@fotoPatrocinador" alt="@patrocinador.Nome"
                                         class="rounded foto-thumb"
                                         style="width:36px;height:36px;object-fit:cover;cursor:pointer;"
                                         data-src="@fotoPatrocinador" data-nome="@patrocinador.Nome"
                                         onerror="this.replaceWith(document.getElementById('avatar-tpl').content.cloneNode(true))" />
                                }
                                else
                                {
                                    <span class="d-inline-flex align-items-center justify-content-center rounded bg-secondary text-white"
                                          style="width:36px;height:36px;font-size:.85rem">
                                        <i class="bi bi-megaphone"></i>
                                    </span>
                                }
                            </td>
                            <td class="fw-semibold">@patrocinador.Nome</td>
                            <td>@(string.IsNullOrWhiteSpace(patrocinador.Instagram) ? "-" : patrocinador.Instagram)</td>
                            <td>@(string.IsNullOrWhiteSpace(patrocinador.Facebook) ? "-" : patrocinador.Facebook)</td>
                            <td>@(string.IsNullOrWhiteSpace(patrocinador.Site) ? "-" : patrocinador.Site)</td>
                            <td>@(string.IsNullOrWhiteSpace(patrocinador.Zap) ? "-" : patrocinador.Zap)</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/@slug/patrocinadores/@patrocinador.Id/editar" class="btn btn-sm btn-outline-secondary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-controller="Patrocinador" asp-action="Remover" asp-route-slug="@slug" asp-route-id="@patrocinador.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remover @patrocinador.Nome?')" title="Remover">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<template id="avatar-tpl">
    <span class="d-inline-flex align-items-center justify-content-center rounded bg-secondary text-white"
          style="width:36px;height:36px;font-size:.85rem">
        <i class="bi bi-megaphone"></i>
    </span>
</template>

<div class="modal fade" id="modalFoto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 bg-transparent shadow-none">
            <div class="modal-body p-0 text-center">
                <img id="modalFotoImg" src="" alt="" class="img-fluid rounded" style="max-height:80vh;" />
                <p id="modalFotoNome" class="text-white mt-2 fw-semibold fs-5 mb-0"></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    (() => {
        const modal     = new bootstrap.Modal(document.getElementById('modalFoto'));
        const modalImg  = document.getElementById('modalFotoImg');
        const modalNome = document.getElementById('modalFotoNome');
        document.querySelectorAll('.foto-thumb').forEach(img => {
            img.addEventListener('click', () => {
                modalImg.src = img.dataset.src;
                modalImg.alt = img.dataset.nome;
                modalNome.textContent = img.dataset.nome;
                modal.show();
            });
        });
    })();
    </script>
}
