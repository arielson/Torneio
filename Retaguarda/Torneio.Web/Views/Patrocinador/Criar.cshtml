@model CriarPatrocinadorDto
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    ViewData["Title"] = "Novo patrocinador";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Novo patrocinador</h1>
    </div>
</div>
<a href="/@slug/patrocinadores" class="back-link">
    <i class="bi bi-arrow-left"></i> Patrocinadores
</a>

<div class="form-card">
    <form asp-controller="Patrocinador" asp-action="Criar" asp-route-slug="@slug" method="post" enctype="multipart/form-data">
        <input asp-for="TorneioId" type="hidden" />
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }

        <div class="form-section-title">Dados do patrocinador</div>
        <div class="mb-3">
            <label asp-for="Nome" class="form-label">Nome</label>
            <input asp-for="Nome" class="form-control" placeholder="Ex.: Pesca Esporte Ltda" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

        <div class="form-section-title"><i class="bi bi-share me-1"></i>Formas de contato <span class="fw-normal text-muted">(todas opcionais — aparecerão como botões na tela do torneio)</span></div>
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="Instagram" class="form-label"><i class="bi bi-instagram me-1"></i>Instagram</label>
                <input asp-for="Instagram" class="form-control" placeholder="@@perfildopatrocinador" />
                <span asp-validation-for="Instagram" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Facebook" class="form-label"><i class="bi bi-facebook me-1"></i>Facebook</label>
                <input asp-for="Facebook" class="form-control" placeholder="facebook.com/pagina ou @@pagina" />
                <span asp-validation-for="Facebook" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Site" class="form-label"><i class="bi bi-globe me-1"></i>Site</label>
                <input asp-for="Site" class="form-control" placeholder="https://www.site.com.br" />
                <span asp-validation-for="Site" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Zap" class="form-label"><i class="bi bi-whatsapp me-1"></i>WhatsApp</label>
                <input asp-for="Zap" class="form-control" placeholder="(71) 99999-9999" inputmode="tel" />
                <span asp-validation-for="Zap" class="text-danger small"></span>
            </div>
        </div>
        <div class="form-check mb-2">
            <input asp-for="ExibirNaTelaInicial" class="form-check-input" />
            <label asp-for="ExibirNaTelaInicial" class="form-check-label">Exibir na tela inicial do torneio</label>
        </div>
        <div class="form-check mb-3">
            <input asp-for="ExibirNosRelatorios" class="form-check-input" />
            <label asp-for="ExibirNosRelatorios" class="form-check-label">Exibir ao final dos relatórios</label>
        </div>

        <div class="form-section-title">Imagem</div>
        <partial name="_FotoUpload" view-data='@(new ViewDataDictionary(ViewData) { { "inputName", "foto" }, { "label", "Imagem do patrocinador" } })' />

        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Criar patrocinador
            </button>
            <a href="/@slug/patrocinadores" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
