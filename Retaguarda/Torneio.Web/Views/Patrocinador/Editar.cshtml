@model AtualizarPatrocinadorDto
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    var patrocinador = (PatrocinadorDto)ViewBag.Patrocinador;
    ViewData["Title"] = $"Editar patrocinador - {patrocinador.Nome}";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Editar patrocinador - @patrocinador.Nome</h1>
    </div>
</div>
<a href="/@slug/patrocinadores" class="back-link">
    <i class="bi bi-arrow-left"></i> Patrocinadores
</a>

<div class="form-card">
    <form asp-controller="Patrocinador" asp-action="Editar" asp-route-slug="@slug" asp-route-id="@patrocinador.Id" method="post" enctype="multipart/form-data">
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }

        <div class="form-section-title">Dados do patrocinador</div>
        <div class="mb-3">
            <label asp-for="Nome" class="form-label">Nome</label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Instagram" class="form-label">Instagram (opcional)</label>
            <input asp-for="Instagram" class="form-control" />
            <span asp-validation-for="Instagram" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Facebook" class="form-label">Facebook (opcional)</label>
            <input asp-for="Facebook" class="form-control" />
            <span asp-validation-for="Facebook" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Site" class="form-label">Site (opcional)</label>
            <input asp-for="Site" class="form-control" />
            <span asp-validation-for="Site" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Zap" class="form-label">Zap (opcional)</label>
            <input asp-for="Zap" class="form-control" />
            <span asp-validation-for="Zap" class="text-danger small"></span>
        </div>
        <div class="form-check mb-2">
            <input asp-for="ExibirNaTelaInicial" class="form-check-input" />
            <label asp-for="ExibirNaTelaInicial" class="form-check-label">Exibir na tela inicial do torneio</label>
        </div>
        <div class="form-check mb-3">
            <input asp-for="ExibirNosRelatorios" class="form-check-input" />
            <label asp-for="ExibirNosRelatorios" class="form-check-label">Exibir ao final dos relatórios</label>
        </div>

        <div class="form-section-title">Imagem</div>
        <partial name="_FotoUpload" view-data='@(new ViewDataDictionary(ViewData) { { "inputName", "foto" }, { "label", "Imagem do patrocinador" }, { "fotoUrl", patrocinador.FotoUrl } })' />

        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Salvar alterações
            </button>
            <a href="/@slug/patrocinadores" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
