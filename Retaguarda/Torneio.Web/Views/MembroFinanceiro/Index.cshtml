@model IEnumerable<Torneio.Application.DTOs.Financeiro.ParcelaTorneioDto>
@{
    var torneio = (TorneioDto?)ViewBag.Torneio;
    ViewData["Title"] = "Minhas cobranças";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Minhas cobranças</h1>
        <p class="text-muted mb-0">@torneio?.NomeTorneio</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Nenhuma cobrança encontrada para o seu cadastro.</div>
}
else
{
    <div class="row g-3">
        @foreach (var cobranca in Model.OrderBy(x => x.Vencimento).ThenBy(x => x.NumeroParcela))
        {
            var badgeClass = cobranca.Pago
                ? "bg-success-subtle text-success"
                : cobranca.Inadimplente
                    ? "bg-danger-subtle text-danger"
                    : "bg-warning-subtle text-warning";
            var status = cobranca.Pago ? "Pago" : cobranca.Inadimplente ? "Inadimplente" : "Em aberto";
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <h5 class="card-title mb-1">@cobranca.Descricao</h5>
                                <div class="text-muted small">Tipo: @cobranca.TipoParcela</div>
                            </div>
                            <span class="badge @badgeClass">@status</span>
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-3"><strong>Valor:</strong> @cobranca.Valor.ToString("C")</div>
                            <div class="col-md-3"><strong>Vencimento:</strong> @cobranca.Vencimento.ToString("dd/MM/yyyy")</div>
                            <div class="col-md-3"><strong>Parcela:</strong> @(cobranca.NumeroParcela > 0 ? cobranca.NumeroParcela.ToString() : "-")</div>
                            <div class="col-md-3"><strong>Pagamento:</strong> @(cobranca.DataPagamento?.ToString("dd/MM/yyyy") ?? "-")</div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(cobranca.Observacao))
                        {
                            <div class="mt-3"><strong>Observação:</strong> @cobranca.Observacao</div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
