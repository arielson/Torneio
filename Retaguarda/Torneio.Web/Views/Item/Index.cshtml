@model IEnumerable<ItemDto>
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    var torneio = (TorneioDto)ViewBag.Torneio;
    var label = torneio?.LabelItem ?? "Item";
    var labelPlural = torneio?.LabelItemPlural ?? "Itens";
    var medida = torneio?.MedidaCaptura ?? "cm";
    var usarFator = torneio?.UsarFatorMultiplicador ?? false;
    ViewData["Title"] = labelPlural;
    var lista = Model.ToList();
    var storageBase = ViewBag.StorageBaseUrl as string ?? "";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>@labelPlural</h1>
    </div>
    <div class="page-header-actions">
        <a href="/@slug/itens/criar" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Novo @label
        </a>
    </div>
</div>
<a href="/@slug/admin" class="back-link">
    <i class="bi bi-arrow-left"></i> Painel
</a>

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-collection me-2"></i>@labelPlural cadastrados</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">
            Nenhum @label.ToLower() cadastrado. <a href="/@slug/itens/criar">Criar o primeiro</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="width:48px"></th>
                        <th>Nome</th>
                        <th>Comprimento min. (@medida)</th>
                        @if (usarFator)
                        {
                            <th>Fator</th>
                        }
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var i in lista)
                    {
                        var fotoItem = string.IsNullOrWhiteSpace(i.FotoUrl) ? null
                            : (i.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? i.FotoUrl : $"{storageBase}/{i.FotoUrl.TrimStart('/')}");
                        <tr>
                            <td>
                                @if (fotoItem != null)
                                {
                                    <img src="@fotoItem" alt="@i.Nome"
                                         class="rounded foto-thumb"
                                         style="width:36px;height:36px;object-fit:cover;cursor:pointer;"
                                         data-src="@fotoItem" data-nome="@i.Nome"
                                         onerror="this.replaceWith(document.getElementById('avatar-tpl').content.cloneNode(true))" />
                                }
                                else
                                {
                                    <span class="d-inline-flex align-items-center justify-content-center rounded bg-secondary text-white"
                                          style="width:36px;height:36px;font-size:.85rem">
                                        <i class="bi bi-fish"></i>
                                    </span>
                                }
                            </td>
                            <td class="fw-semibold">@i.Nome</td>
                            <td>@(i.Comprimento?.ToString("F2") ?? "-")</td>
                            @if (usarFator)
                            {
                                <td>
                                    @if (i.FatorMultiplicador != 1.0m)
                                    {
                                        <span class="badge bg-info-subtle text-info border border-info-subtle">@i.FatorMultiplicador.ToString("F2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">1,00</span>
                                    }
                                </td>
                            }
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/@slug/itens/@i.Id/editar" class="btn btn-sm btn-outline-secondary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-controller="Item" asp-action="Remover" asp-route-slug="@slug" asp-route-id="@i.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remover @i.Nome?')" title="Remover">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<template id="avatar-tpl">
    <span class="d-inline-flex align-items-center justify-content-center rounded bg-secondary text-white"
          style="width:36px;height:36px;font-size:.85rem">
        <i class="bi bi-fish"></i>
    </span>
</template>

<div class="modal fade" id="modalFoto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 bg-transparent shadow-none">
            <div class="modal-body p-0 text-center">
                <img id="modalFotoImg" src="" alt="" class="img-fluid rounded" style="max-height:80vh;" />
                <p id="modalFotoNome" class="text-white mt-2 fw-semibold fs-5 mb-0"></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    (() => {
        const modal     = new bootstrap.Modal(document.getElementById('modalFoto'));
        const modalImg  = document.getElementById('modalFotoImg');
        const modalNome = document.getElementById('modalFotoNome');
        document.querySelectorAll('.foto-thumb').forEach(img => {
            img.addEventListener('click', () => {
                modalImg.src = img.dataset.src;
                modalImg.alt = img.dataset.nome;
                modalNome.textContent = img.dataset.nome;
                modal.show();
            });
        });
    })();
    </script>
}
