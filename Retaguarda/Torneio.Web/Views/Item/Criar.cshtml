@model CriarItemDto
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    var torneio = (TorneioDto)ViewBag.Torneio;
    var especies = (IEnumerable<EspeciePeixeDto>)(ViewBag.Especies ?? Enumerable.Empty<EspeciePeixeDto>());
    var label = torneio?.LabelItem ?? "Item";
    var labelPlural = torneio?.LabelItemPlural ?? "Itens";
    var medida = torneio?.MedidaCaptura ?? "cm";
    var usarFator = torneio?.UsarFatorMultiplicador ?? false;
    var storageBase = ViewBag.StorageBaseUrl as string ?? "";
    var jaAdicionadas = ViewBag.EspeciesJaAdicionadas as HashSet<Guid> ?? new HashSet<Guid>();
    ViewData["Title"] = $"Adicionar {label}";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Adicionar @label ao Torneio</h1>
    </div>
</div>
<a href="/@slug/itens" class="back-link">
    <i class="bi bi-arrow-left"></i> @labelPlural
</a>

<div class="form-card">
    <form asp-controller="Item" asp-action="Criar" asp-route-slug="@slug" method="post">
        <input asp-for="TorneioId" type="hidden" />
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }

        <div class="form-section-title">Espécie</div>
        @if (!especies.Any())
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle me-2"></i>
                Nenhuma espécie cadastrada no sistema. <a href="/admin/especies/criar" target="_blank">Criar espécies</a> antes de adicionar itens ao torneio.
            </div>
        }
        else
        {
            <div class="row g-3 mb-3">
                <!-- Grid de seleção -->
                <div class="col-lg-8">
                    <label class="form-label">Selecione a espécie</label>
                    <div class="row g-2" id="especiesGrid">
                        @foreach (var e in especies.OrderBy(x => x.Nome))
                        {
                            var fotoUrl = string.IsNullOrWhiteSpace(e.FotoUrl) ? null
                                : (e.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? e.FotoUrl : $"{storageBase}/{e.FotoUrl.TrimStart('/')}");
                            var jaAdicionada = jaAdicionadas.Contains(e.Id);
                            <div class="col-6 col-sm-4 col-md-3">
                                <label class="especie-card @(Model.EspeciePeixeId == e.Id ? "selected" : "") @(jaAdicionada ? "ja-adicionada" : "")"
                                       data-id="@e.Id"
                                       data-nome="@e.Nome"
                                       data-cientifico="@(e.NomeCientifico ?? "")"
                                       data-foto="@(fotoUrl ?? "")">
                                    <input type="radio" name="EspeciePeixeId" value="@e.Id"
                                           @(Model.EspeciePeixeId == e.Id ? "checked" : "")
                                           @(jaAdicionada ? "disabled" : "")
                                           class="d-none especie-radio" />
                                    @if (fotoUrl != null)
                                    {
                                        <img src="@fotoUrl" alt="@e.Nome"
                                             style="width:56px;height:56px;object-fit:cover;border-radius:8px;"
                                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                        <span class="especie-placeholder" style="display:none">
                                            <i class="bi bi-collection"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="especie-placeholder">
                                            <i class="bi bi-collection"></i>
                                        </span>
                                    }
                                    <span class="especie-nome">@e.Nome</span>
                                </label>
                            </div>
                        }
                    </div>
                    <span asp-validation-for="EspeciePeixeId" class="text-danger small"></span>
                </div>

                <!-- Preview da espécie selecionada -->
                <div class="col-lg-4">
                    <label class="form-label d-none d-lg-block">&nbsp;</label>
                    <div id="especiePreview" class="especie-preview">
                        <div id="previewVazio" class="especie-preview-vazio">
                            <i class="bi bi-collection fs-1 text-secondary"></i>
                            <span class="text-muted small mt-2">Selecione uma espécie</span>
                        </div>
                        <div id="previewConteudo" style="display:none">
                            <div id="previewFotoWrap" class="mb-3">
                                <img id="previewFoto" src="" alt=""
                                     style="width:100%;max-height:260px;object-fit:cover;border-radius:10px;" />
                                <div id="previewFotoPlaceholder" class="especie-preview-placeholder" style="display:none">
                                    <i class="bi bi-collection"></i>
                                </div>
                            </div>
                            <div class="fw-bold fs-6" id="previewNome"></div>
                            <div class="text-muted fst-italic small mt-1" id="previewCientifico"></div>
                            <div class="mt-2">
                                <span class="badge bg-success-subtle text-success border border-success-subtle">
                                    <i class="bi bi-check-circle me-1"></i>Selecionada
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="form-section-title">Configurações no Torneio</div>
        <div class="row g-3 mb-2">
            <div class="@(usarFator ? "col-md-6" : "col-12")">
                <label asp-for="Comprimento" class="form-label">Comprimento mínimo (@medida) <span class="text-muted">- opcional</span></label>
                <input asp-for="Comprimento" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="Comprimento" class="text-danger small"></span>
            </div>
            @if (usarFator)
            {
                <div class="col-md-6">
                    <label asp-for="FatorMultiplicador" class="form-label">Fator Multiplicador</label>
                    <input asp-for="FatorMultiplicador" class="form-control" type="number" step="0.01" min="0.01" value="1.00" />
                    <span asp-validation-for="FatorMultiplicador" class="text-danger small"></span>
                </div>
            }
            else
            {
                <input asp-for="FatorMultiplicador" type="hidden" value="1.00" />
            }
        </div>

        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Adicionar ao Torneio
            </button>
            <a href="/@slug/itens" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

<style>
.especie-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    padding: 8px 6px;
    border: 2px solid #dee2e6;
    border-radius: 10px;
    cursor: pointer;
    text-align: center;
    transition: border-color .15s, background .15s;
    background: #fff;
    min-height: 100px;
    justify-content: center;
}
.especie-card:hover { border-color: #0d6efd; background: #f0f6ff; }
.especie-card.selected { border-color: #0d6efd; background: #e8f0fe; box-shadow: 0 0 0 3px rgba(13,110,253,.15); }
.especie-placeholder {
    width: 56px; height: 56px;
    border-radius: 8px;
    background: #e9ecef;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; color: #6c757d;
}
.especie-nome { font-size: .8rem; font-weight: 600; line-height: 1.2; word-break: break-word; }
.ja-adicionada { opacity: .45; cursor: not-allowed; pointer-events: none; }
.ja-adicionada::after {
    content: "Já adicionada";
    font-size: .65rem; color: #6c757d;
    display: block; margin-top: 2px;
}

.especie-preview {
    border: 2px solid #dee2e6;
    border-radius: 12px;
    padding: 16px;
    background: #fff;
    min-height: 180px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}
.especie-preview-vazio {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 140px;
    opacity: .5;
}
.especie-preview-placeholder {
    width: 100%; height: 140px;
    border-radius: 10px;
    background: #e9ecef;
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem; color: #6c757d;
}
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (() => {
        const vazio     = document.getElementById('previewVazio');
        const conteudo  = document.getElementById('previewConteudo');
        const foto      = document.getElementById('previewFoto');
        const fotoPh    = document.getElementById('previewFotoPlaceholder');
        const nome      = document.getElementById('previewNome');
        const cient     = document.getElementById('previewCientifico');

        function selecionarCard(card) {
            document.querySelectorAll('.especie-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            card.querySelector('.especie-radio').checked = true;

            const nomeTxt   = card.dataset.nome;
            const cienTxt   = card.dataset.cientifico;
            const fotoSrc   = card.dataset.foto;

            nome.textContent  = nomeTxt;
            cient.textContent = cienTxt;
            cient.style.display = cienTxt ? '' : 'none';

            if (fotoSrc) {
                foto.src = fotoSrc;
                foto.alt = nomeTxt;
                foto.style.display = '';
                fotoPh.style.display = 'none';
                foto.onerror = () => { foto.style.display = 'none'; fotoPh.style.display = 'flex'; };
            } else {
                foto.style.display = 'none';
                fotoPh.style.display = 'flex';
            }

            vazio.style.display    = 'none';
            conteudo.style.display = '';
        }

        document.querySelectorAll('.especie-card:not(.ja-adicionada)').forEach(card => {
            card.addEventListener('click', () => selecionarCard(card));
        });

        // Inicializa preview se já há seleção (erro de validação)
        const selecionado = document.querySelector('.especie-card.selected');
        if (selecionado) selecionarCard(selecionado);
    })();
    </script>
}
