@model IEnumerable<MembroDto>
@{
    var slug        = Context.GetRouteData().Values["slug"]?.ToString();
    var equipe      = (EquipeDto)ViewBag.Equipe;
    var torneio     = (TorneioDto)ViewBag.Torneio;
    var labelEquipe      = torneio?.LabelEquipe ?? "Equipe";
    var labelEquipePlural = torneio?.LabelEquipePlural ?? "Equipes";
    var labelMembro      = torneio?.LabelMembro ?? "Membro";
    var labelMembroPlural = torneio?.LabelMembroPlural ?? "Membros";
    ViewData["Title"] = $"{labelMembroPlural} — {equipe.Nome}";
    var membroIds = equipe.MembroIds.ToHashSet();
    var naEquipe  = Model.Where(m => membroIds.Contains(m.Id)).OrderBy(m => m.Nome).ToList();
    var fora      = Model.Where(m => !membroIds.Contains(m.Id)).OrderBy(m => m.Nome).ToList();
    var cheio     = equipe.QtdMembros >= equipe.QtdVagas;
}

<div class="page-header">
    <div class="page-header-left">
        <h1>@labelMembroPlural — @equipe.Nome</h1>
    </div>
</div>
<a href="/@slug/equipes" class="back-link">
    <i class="bi bi-arrow-left"></i> @labelEquipePlural
</a>

<div class="d-flex gap-3 mb-4 flex-wrap">
    <div class="stat-card" style="flex:0 0 auto">
        <div class="stat-icon @(cheio ? "green" : "amber")">
            <i class="bi bi-people"></i>
        </div>
        <div>
            <div class="stat-value">@equipe.QtdMembros / @equipe.QtdVagas</div>
            <div class="stat-label">vagas preenchidas</div>
        </div>
    </div>
</div>

<!-- Membros na equipe -->
<div class="content-card mb-3">
    <div class="card-header-bar">
        <h5><i class="bi bi-people-fill me-2"></i>@labelMembroPlural nesta @labelEquipe.ToLower()</h5>
    </div>
    @if (!naEquipe.Any())
    {
        <div class="card-body-pad text-muted">
            Nenhum @labelMembro.ToLower() alocado ainda.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>@labelMembro</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in naEquipe)
                    {
                        <tr>
                            <td class="fw-semibold">@m.Nome</td>
                            <td class="text-end">
                                <form asp-controller="Equipe" asp-action="RemoverMembro"
                                      asp-route-slug="@slug"
                                      asp-route-id="@equipe.Id" asp-route-membroId="@m.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" title="Remover"
                                            onclick="return confirm('Remover @m.Nome desta @labelEquipe.ToLower()?')">
                                        <i class="bi bi-dash-lg"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Membros disponíveis para adicionar -->
@if (fora.Any())
{
    <div class="content-card">
        <div class="card-header-bar">
            <h5><i class="bi bi-person-plus me-2"></i>Adicionar @labelMembro.ToLower()</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>@labelMembro</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in fora)
                    {
                        <tr>
                            <td class="fw-semibold">@m.Nome</td>
                            <td class="text-end">
                                <form asp-controller="Equipe" asp-action="AdicionarMembro"
                                      asp-route-slug="@slug"
                                      asp-route-id="@equipe.Id" asp-route-membroId="@m.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-success" title="Adicionar">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
