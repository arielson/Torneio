@model AtualizarEquipeDto
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    var equipe = (EquipeDto)ViewBag.Equipe;
    var torneio = (TorneioDto)ViewBag.Torneio;
    var label = torneio?.LabelEquipe ?? "Equipe";
    var labelPlural = torneio?.LabelEquipePlural ?? "Equipes";
    var exibirVagas = !string.Equals(torneio?.ModoSorteio, nameof(ModoSorteio.Nenhum), StringComparison.Ordinal);
    var exibirFinanceiro = torneio?.ExibirModuloFinanceiro ?? true;
    ViewData["Title"] = $"Editar {label} - {equipe.Nome}";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Editar @label - @equipe.Nome</h1>
    </div>
</div>
<a href="/@slug/equipes" class="back-link">
    <i class="bi bi-arrow-left"></i> @labelPlural
</a>

<div class="form-card">
    <form asp-controller="Equipe" asp-action="Editar" asp-route-slug="@slug" asp-route-id="@equipe.Id" method="post" enctype="multipart/form-data">
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }
        <div class="form-section-title">Dados da @label</div>
        <div class="mb-3">
            <label asp-for="Nome" class="form-label">Nome da @label</label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Capitao" class="form-label">Capitao</label>
            <input asp-for="Capitao" class="form-control" />
            <span asp-validation-for="Capitao" class="text-danger small"></span>
        </div>
        @if (exibirVagas)
        {
            <div class="mb-3">
                <label asp-for="QtdVagas" class="form-label">Quantidade de Vagas</label>
                <input asp-for="QtdVagas" class="form-control" type="number" min="1" style="max-width:160px" />
                <span asp-validation-for="QtdVagas" class="text-danger small"></span>
            </div>
        }
        else
        {
            <input asp-for="QtdVagas" type="hidden" value="1" />
        }
        @if (exibirFinanceiro)
        {
            <div class="form-section-title">Financeiro da embarcacao</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Custo" class="form-label">Custo</label>
                    <input asp-for="Custo" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Custo" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="StatusFinanceiro" class="form-label">Status</label>
                    <select asp-for="StatusFinanceiro" class="form-select" asp-items="Html.GetEnumSelectList<StatusEmbarcacaoFinanceira>()"></select>
                    <span asp-validation-for="StatusFinanceiro" class="text-danger small"></span>
                </div>
            </div>
        }
        else
        {
            <input asp-for="Custo" type="hidden" value="@Model.Custo" />
            <input asp-for="StatusFinanceiro" type="hidden" value="@Model.StatusFinanceiro" />
        }
        <div class="form-section-title">Fotos</div>
        <partial name="_FotoUpload" view-data='@(new ViewDataDictionary(ViewData) { { "inputName", "foto" }, { "label", $"Foto da {label}" }, { "fotoUrl", equipe.FotoUrl } })' />
        <partial name="_FotoUpload" view-data='@(new ViewDataDictionary(ViewData) { { "inputName", "fotoCapitao" }, { "label", "Foto do Capitao" }, { "fotoUrl", equipe.FotoCapitaoUrl } })' />
        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Salvar Alteracoes
            </button>
            <a href="/@slug/equipes" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
