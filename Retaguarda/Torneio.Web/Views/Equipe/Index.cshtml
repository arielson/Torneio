@model IEnumerable<EquipeDto>
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    var torneio = (TorneioDto)ViewBag.Torneio;
    var label = torneio?.LabelEquipe ?? "Equipe";
    var labelPlural = torneio?.LabelEquipePlural ?? "Equipes";
    var labelMembroPlural = torneio?.LabelMembroPlural ?? "Membros";
    var exibirMembrosPorEquipe = !string.Equals(torneio?.ModoSorteio, nameof(ModoSorteio.Nenhum), StringComparison.Ordinal);
    var exibirVagas = !string.Equals(torneio?.ModoSorteio, nameof(ModoSorteio.Nenhum), StringComparison.Ordinal);
    var exibirFinanceiro = torneio?.ExibirModuloFinanceiro ?? true;
    ViewData["Title"] = labelPlural;
    var lista = Model.ToList();
    var storageBase = ViewBag.StorageBaseUrl as string ?? "";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>@labelPlural</h1>
    </div>
    <div class="page-header-actions">
        @if (exibirMembrosPorEquipe)
        {
            <a href="/@slug/equipes/reorganizacao-emergencial" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-exclamation-triangle me-1"></i>Reorganização Emergencial
            </a>
        }
        @if (User.HasClaim("perfil", "AdminGeral"))
        {
            <a href="/@slug/equipes/importar" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-box-arrow-in-down me-1"></i>Importar
            </a>
        }
        <a href="/@slug/equipes/criar" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nova @label
        </a>
    </div>
</div>
<a href="/@slug/admin" class="back-link">
    <i class="bi bi-arrow-left"></i> Painel
</a>

<div class="content-card">
    @if (exibirMembrosPorEquipe)
    {
        <div class="alert alert-warning m-3 mb-0">
            Reorganização de @labelMembroPlural.ToLower() entre @labelPlural.ToLower() deve ser usada apenas em emergência e sempre com confirmação do admin do torneio.
        </div>
    }
    <div class="card-header-bar">
        <h5><i class="bi bi-people me-2"></i>@labelPlural cadastradas</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">
            Nenhuma @label.ToLower() cadastrada. <a href="/@slug/equipes/criar">Criar a primeira</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="width:48px"></th>
                        <th>Nome</th>
                        <th>Capitão</th>
                        @if (exibirVagas)
                        {
                            <th>Vagas</th>
                        }
                        @if (exibirMembrosPorEquipe)
                        {
                            <th>@labelMembroPlural</th>
                        }
                        @if (exibirFinanceiro)
                        {
                            <th>Custo</th>
                            <th>Vencimento do custo</th>
                            <th>Status financeiro</th>
                        }
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in lista)
                    {
                        var fotoEquipe = string.IsNullOrWhiteSpace(e.FotoUrl) ? null
                            : (e.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? e.FotoUrl : $"{storageBase}/{e.FotoUrl.TrimStart('/')}");
                        var fotoCapitao = string.IsNullOrWhiteSpace(e.FotoCapitaoUrl) ? null
                            : (e.FotoCapitaoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? e.FotoCapitaoUrl : $"{storageBase}/{e.FotoCapitaoUrl.TrimStart('/')}");
                        <tr>
                            <td>
                                @if (fotoEquipe != null)
                                {
                                    <img src="@fotoEquipe" alt="@e.Nome"
                                         class="rounded foto-thumb"
                                         style="width:36px;height:36px;object-fit:cover;cursor:pointer;"
                                         data-src="@fotoEquipe" data-nome="@e.Nome"
                                         onerror="this.replaceWith(document.getElementById('avatar-tpl').content.cloneNode(true))" />
                                }
                                else
                                {
                                    <span class="d-inline-flex align-items-center justify-content-center rounded bg-secondary text-white"
                                          style="width:36px;height:36px;font-size:.85rem">
                                        <i class="bi bi-people"></i>
                                    </span>
                                }
                            </td>
                            <td class="fw-semibold">@e.Nome</td>
                            <td>
                                @if (fotoCapitao != null)
                                {
                                    <img src="@fotoCapitao" alt="@e.Capitao"
                                         class="rounded-circle foto-thumb me-1"
                                         style="width:28px;height:28px;object-fit:cover;cursor:pointer;vertical-align:middle;"
                                         data-src="@fotoCapitao" data-nome="@e.Capitao"
                                         onerror="this.style.display='none'" />
                                }
                                @e.Capitao
                            </td>
                            @if (exibirVagas)
                            {
                                <td>@e.QtdVagas</td>
                            }
                            @if (exibirMembrosPorEquipe)
                            {
                                <td>
                                    <span class="@(e.QtdMembros >= e.QtdVagas ? "text-success fw-semibold" : "")">
                                        @e.QtdMembros / @e.QtdVagas
                                    </span>
                                </td>
                            }
                            @if (exibirFinanceiro)
                            {
                                <td>R$ @e.Custo.ToString("N2")</td>
                                <td>@(e.DataVencimentoCusto.HasValue ? e.DataVencimentoCusto.Value.ToString("dd/MM/yyyy") : "-")</td>
                                <td>@e.StatusFinanceiro</td>
                            }
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end flex-wrap">
                                    @if (exibirMembrosPorEquipe)
                                    {
                                        <a href="/@slug/equipes/@e.Id/membros" class="btn btn-sm btn-outline-secondary" title="@labelMembroPlural">
                                            <i class="bi bi-person me-1"></i>@labelMembroPlural
                                        </a>
                                    }
                                    <a href="/@slug/equipes/@e.Id/editar" class="btn btn-sm btn-outline-secondary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-controller="Equipe" asp-action="Remover" asp-route-slug="@slug" asp-route-id="@e.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remover @e.Nome?')" title="Remover">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<template id="avatar-tpl">
    <span class="d-inline-flex align-items-center justify-content-center rounded bg-secondary text-white"
          style="width:36px;height:36px;font-size:.85rem">
        <i class="bi bi-people"></i>
    </span>
</template>

<div class="modal fade" id="modalFoto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 bg-transparent shadow-none">
            <div class="modal-body p-0 text-center">
                <img id="modalFotoImg" src="" alt="" class="img-fluid rounded" style="max-height:80vh;" />
                <p id="modalFotoNome" class="text-white mt-2 fw-semibold fs-5 mb-0"></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    (() => {
        const modal     = new bootstrap.Modal(document.getElementById('modalFoto'));
        const modalImg  = document.getElementById('modalFotoImg');
        const modalNome = document.getElementById('modalFotoNome');
        document.querySelectorAll('.foto-thumb').forEach(img => {
            img.addEventListener('click', () => {
                modalImg.src = img.dataset.src;
                modalImg.alt = img.dataset.nome;
                modalNome.textContent = img.dataset.nome;
                modal.show();
            });
        });
    })();
    </script>
}
