@using Torneio.Application.DTOs.Asaas
@using Torneio.Application.DTOs.Torneio
@model SalvarConfiguracaoAsaasDto
@{
    var torneio = ViewBag.Torneio as TorneioDto;
    var configAtual = ViewBag.ConfigAtual as ConfiguracaoAsaasDto;
    var jaConfigurada = configAtual is not null;
    var statusAtual = configAtual?.StatusChave ?? "NaoConfigurada";
    ViewData["Title"] = $"Asaas — {torneio?.NomeTorneio}";
}

<div class="page-header">
    <div class="page-header-left">
        <h1><i class="bi bi-credit-card-2-front me-2"></i>Integração Asaas</h1>
        <p class="text-muted mb-0">@torneio?.NomeTorneio</p>
    </div>
</div>
<a href="/admin/asaas" class="back-link">
    <i class="bi bi-arrow-left"></i> Integrações Asaas
</a>

@if (jaConfigurada)
{
    <div class="content-card mb-3">
        <div class="card-body-pad">
            <div class="d-flex align-items-center gap-3">
                <div>
                    <span class="fw-semibold me-2">Status:</span>
                    @if (statusAtual == "Ativa")
                    {
                        <span class="badge bg-success fs-6">Ativa</span>
                    }
                    else if (statusAtual == "Inativa")
                    {
                        <span class="badge bg-secondary fs-6">Inativa</span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(configAtual?.AsaasAccountId))
                {
                    <div class="text-muted small">
                        <i class="bi bi-person-check me-1"></i>Account ID: @configAtual.AsaasAccountId
                    </div>
                }
                @if (configAtual?.DataAtivacao is not null)
                {
                    <div class="text-muted small">
                        <i class="bi bi-calendar me-1"></i>Ativada em: @configAtual.DataAtivacao.Value.ToString("dd/MM/yyyy")
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="form-card">
    <form asp-controller="AsaasAdmin"
          asp-action="SalvarConfiguracao"
          asp-route-torneioId="@Model.TorneioId"
          method="post">

        <input asp-for="TorneioId" type="hidden" />

        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }

        <div class="form-section-title">Chave de API</div>

        <div class="mb-3">
            <label asp-for="ChaveApiAsaas" class="form-label">
                Chave de API do Asaas
                <span class="text-danger">*</span>
            </label>
            @if (jaConfigurada)
            {
                <input asp-for="ChaveApiAsaas"
                       class="form-control"
                       placeholder="Já configurada — cole a nova chave para alterar"
                       autocomplete="off" />
                <div class="form-text">
                    <i class="bi bi-shield-lock me-1"></i>
                    A chave atual está salva. Preencha apenas para substituí-la.
                </div>
            }
            else
            {
                <input asp-for="ChaveApiAsaas"
                       class="form-control"
                       placeholder="$aact_..."
                       autocomplete="off" />
            }
            <span asp-validation-for="ChaveApiAsaas" class="text-danger small"></span>
        </div>

        <div class="form-section-title mt-4">Formas de pagamento aceitas</div>

        <div class="mb-2">
            <div class="form-check">
                <input asp-for="AceitarPix" class="form-check-input" />
                <label asp-for="AceitarPix" class="form-check-label">
                    <i class="bi bi-qr-code me-1"></i>PIX
                </label>
            </div>
        </div>
        <div class="mb-3">
            <div class="form-check">
                <input asp-for="AceitarCartaoCredito" class="form-check-input" />
                <label asp-for="AceitarCartaoCredito" class="form-check-label">
                    <i class="bi bi-credit-card me-1"></i>Cartão de crédito
                </label>
            </div>
        </div>

        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Salvar
            </button>
            <a href="/admin/asaas" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@if (jaConfigurada && statusAtual == "Ativa")
{
    <div class="content-card mt-3">
        <div class="card-body-pad">
            <div class="form-section-title">Webhook de Notificações</div>
            <p class="text-muted small mb-3">
                O webhook recebe notificações automáticas do Asaas quando um pagamento é confirmado,
                recebido, vencido ou estornado. Registre-o após salvar a chave de API.
            </p>
            <form asp-action="RegistrarWebhook"
                  asp-route-torneioId="@Model.TorneioId"
                  method="post"
                  class="d-inline"
                  onsubmit="btnWebhook.disabled=true;btnWebhook.innerHTML='<span class=\'spinner-border spinner-border-sm me-1\' role=\'status\'></span>Registrando...'">
                @Html.AntiForgeryToken()
                <button id="btnWebhook" type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-arrow-repeat me-1"></i>Registrar / Atualizar Webhook
                </button>
            </form>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
