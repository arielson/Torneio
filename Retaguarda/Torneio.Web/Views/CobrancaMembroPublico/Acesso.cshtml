@{
    ViewData["Title"] = "Acessar Cobranças";
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
    var slug    = ViewContext.RouteData.Values["slug"]?.ToString();
    var celular = ViewContext.RouteData.Values["celular"]?.ToString();
    var membroEncontrado = ViewBag.MembroEncontrado as bool? ?? false;
    var temCpf           = ViewBag.TemCpf as bool? ?? false;
}

<div class="row justify-content-center mt-4">
    <div class="col-sm-10 col-md-6 col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body p-4">

                @if (ViewBag.Erro != null)
                {
                    <div class="alert alert-danger py-2 small">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>@ViewBag.Erro
                    </div>
                }

                @if (!membroEncontrado)
                {
                    <h5 class="card-title mb-2">Número não encontrado</h5>
                    <p class="text-muted small mb-0">
                        Este número não está cadastrado neste torneio.
                        Entre em contato com o organizador.
                    </p>
                }
                else if (!temCpf)
                {
                    <h5 class="card-title mb-1">Cadastre seu CPF</h5>
                    <p class="text-muted small mb-4">
                        Para acessar suas cobranças pela primeira vez, informe seu CPF.
                        Ele será salvo no seu cadastro e usado para acessos futuros.
                    </p>

                    <form method="post" asp-action="Verificar" asp-route-slug="@slug" asp-route-celular="@celular">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">CPF</label>
                            <input type="text"
                                   id="inputCpf"
                                   name="cpf"
                                   class="form-control"
                                   placeholder="000.000.000-00"
                                   inputmode="numeric"
                                   autocomplete="off"
                                   autofocus
                                   maxlength="14" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-person-check me-1"></i>Cadastrar e acessar
                        </button>
                    </form>
                }
                else
                {
                    <h5 class="card-title mb-1">Minhas Cobranças</h5>
                    <p class="text-muted small mb-4">Digite seu CPF para acessar suas cobranças.</p>

                    <form method="post" asp-action="Verificar" asp-route-slug="@slug" asp-route-celular="@celular">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">CPF</label>
                            <input type="text"
                                   id="inputCpf"
                                   name="cpf"
                                   class="form-control"
                                   placeholder="000.000.000-00"
                                   inputmode="numeric"
                                   autocomplete="off"
                                   autofocus
                                   maxlength="14" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Acessar
                        </button>
                    </form>
                }

            </div>
        </div>

        <div class="text-center mt-3">
            <a href="/@slug" class="text-muted small">
                <i class="bi bi-arrow-left me-1"></i>Voltar para a página do torneio
            </a>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var input = document.getElementById('inputCpf');
    if (!input) return;
    input.addEventListener('input', function () {
        var d = this.value.replace(/\D/g, '').substring(0, 11);
        var f = '';
        if (d.length <= 3)       f = d;
        else if (d.length <= 6)  f = d.slice(0,3) + '.' + d.slice(3);
        else if (d.length <= 9)  f = d.slice(0,3) + '.' + d.slice(3,6) + '.' + d.slice(6);
        else                      f = d.slice(0,3) + '.' + d.slice(3,6) + '.' + d.slice(6,9) + '-' + d.slice(9);
        this.value = f;
    });
})();
</script>
}
