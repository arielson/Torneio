@{
    ViewData["Title"] = "Criar Senha";
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var celular = ViewContext.RouteData.Values["celular"]?.ToString();
}

<div class="row justify-content-center mt-4">
    <div class="col-sm-10 col-md-6 col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h5 class="card-title mb-1">Crie sua senha</h5>
                <p class="text-muted small mb-4">Escolha uma senha de pelo menos 6 caracteres.</p>

                @if (ViewBag.Erro != null)
                {
                    <div class="alert alert-danger py-2 small">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>@ViewBag.Erro
                    </div>
                }

                <form method="post" asp-action="DefinirSenha" asp-route-slug="@slug" asp-route-celular="@celular">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nova senha</label>
                        <input type="password"
                               name="senha"
                               class="form-control"
                               autocomplete="new-password"
                               autofocus
                               minlength="6" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Confirmar senha</label>
                        <input type="password"
                               name="confirmar"
                               class="form-control"
                               autocomplete="new-password"
                               minlength="6" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-lock-fill me-1"></i>Salvar senha e acessar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
