@model Torneio.Application.DTOs.Grupo.AtualizarGrupoDto
@{ ViewData["Title"] = "Editar Grupo"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <h4 class="mb-3"><i class="bi bi-pencil me-2"></i>Editar Grupo</h4>

        <form asp-action="Editar" asp-route-slug="@ViewBag.Torneio?.Slug" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Nome do grupo *</label>
                <input asp-for="Nome" class="form-control" autofocus />
                <span asp-validation-for="Nome" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Salvar
                </button>
                <a asp-action="Index" asp-route-slug="@ViewBag.Torneio?.Slug" class="btn btn-outline-secondary">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>
