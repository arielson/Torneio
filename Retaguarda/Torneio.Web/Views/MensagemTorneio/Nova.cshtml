@{
    ViewData["Title"] = "Nova Mensagem";
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
}

<div class="page-header mb-4">
    <a href="/@slug/mensagens" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
    <h1 class="h3 mb-0">Nova Mensagem</h1>
    <p class="text-muted">Será exibida no mural público e enviada como notificação push para os seguidores.</p>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var erro in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@erro.ErrorMessage</div>
                }
            </div>
        }
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-semibold">Título <span class="text-danger">*</span></label>
                <input type="text" name="Titulo" class="form-control" maxlength="200"
                       placeholder="Ex: Ranking atualizado!" required />
                <div class="form-text">Aparece como título da notificação push.</div>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Mensagem <span class="text-danger">*</span></label>
                <textarea name="Corpo" class="form-control" rows="4" maxlength="1000"
                          placeholder="Digite a mensagem para os seguidores..." required></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send me-1"></i>Enviar
                </button>
                <a href="/@slug/mensagens" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
