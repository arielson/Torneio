@model AtualizarEspeciePeixeDto
@{
    var especie = (EspeciePeixeDto)ViewBag.Especie;
    ViewData["Title"] = $"Editar Espécie - {especie.Nome}";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Editar Espécie - @especie.Nome</h1>
    </div>
</div>
<a href="/admin/especies" class="back-link">
    <i class="bi bi-arrow-left"></i> Espécies
</a>

<div class="form-card">
    <form asp-controller="EspeciePeixe" asp-action="Editar" asp-route-id="@especie.Id" method="post" enctype="multipart/form-data">
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }
        <div class="form-section-title">Dados da Espécie</div>
        <div class="mb-3">
            <label asp-for="Nome" class="form-label">Nome</label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="NomeCientifico" class="form-label">Nome Científico <span class="text-muted">(opcional)</span></label>
            <input asp-for="NomeCientifico" class="form-control" />
            <span asp-validation-for="NomeCientifico" class="text-danger small"></span>
        </div>
        <div class="form-section-title">Foto</div>
        <partial name="_FotoUpload" view-data='@(new ViewDataDictionary(ViewData) { { "inputName", "foto" }, { "label", "Foto da espécie" }, { "fotoUrl", especie.FotoUrl } })' />
        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Salvar Alterações
            </button>
            <a href="/admin/especies" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
