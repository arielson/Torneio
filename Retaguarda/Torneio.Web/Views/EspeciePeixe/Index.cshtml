@model IEnumerable<EspeciePeixeDto>
@{
    ViewData["Title"] = "Espécies de Peixe";
    var lista = Model.ToList();
    var storageBase = ViewBag.StorageBaseUrl as string ?? "";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Espécies de Peixe</h1>
    </div>
    <div class="page-header-actions">
        <a href="/admin/especies/criar" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nova Espécie
        </a>
    </div>
</div>
<a href="/admin" class="back-link">
    <i class="bi bi-arrow-left"></i> Painel
</a>

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-collection me-2"></i>Espécies cadastradas</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">
            Nenhuma espécie cadastrada. <a href="/admin/especies/criar">Criar a primeira</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="width:48px"></th>
                        <th>Nome</th>
                        <th>Nome Científico</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in lista)
                    {
                        var fotoUrl = string.IsNullOrWhiteSpace(e.FotoUrl) ? null
                            : (e.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? e.FotoUrl : $"{storageBase}/{e.FotoUrl.TrimStart('/')}");
                        <tr>
                            <td>
                                @if (fotoUrl != null)
                                {
                                    <img src="@fotoUrl" alt="@e.Nome"
                                         class="rounded foto-thumb"
                                         style="width:36px;height:36px;object-fit:cover;cursor:pointer;"
                                         data-src="@fotoUrl" data-nome="@e.Nome"
                                         onerror="this.replaceWith(document.getElementById('avatar-tpl').content.cloneNode(true))" />
                                }
                                else
                                {
                                    <span class="d-inline-flex align-items-center justify-content-center rounded bg-secondary text-white"
                                          style="width:36px;height:36px;font-size:.85rem">
                                        <i class="bi bi-collection"></i>
                                    </span>
                                }
                            </td>
                            <td class="fw-semibold">@e.Nome</td>
                            <td class="text-muted fst-italic small">@(e.NomeCientifico ?? "—")</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/admin/especies/@e.Id/editar" class="btn btn-sm btn-outline-secondary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-controller="EspeciePeixe" asp-action="Remover" asp-route-id="@e.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remover @e.Nome? Isso afetará todos os torneios que usam essa espécie.')" title="Remover">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<template id="avatar-tpl">
    <span class="d-inline-flex align-items-center justify-content-center rounded bg-secondary text-white"
          style="width:36px;height:36px;font-size:.85rem">
        <i class="bi bi-collection"></i>
    </span>
</template>

<div class="modal fade" id="modalFoto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 bg-transparent shadow-none">
            <div class="modal-body p-0 text-center">
                <img id="modalFotoImg" src="" alt="" class="img-fluid rounded" style="max-height:80vh;" />
                <p id="modalFotoNome" class="text-white mt-2 fw-semibold fs-5 mb-0"></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    (() => {
        const modal     = new bootstrap.Modal(document.getElementById('modalFoto'));
        const modalImg  = document.getElementById('modalFotoImg');
        const modalNome = document.getElementById('modalFotoNome');
        document.querySelectorAll('.foto-thumb').forEach(img => {
            img.addEventListener('click', () => {
                modalImg.src = img.dataset.src;
                modalImg.alt = img.dataset.nome;
                modalNome.textContent = img.dataset.nome;
                modal.show();
            });
        });
    })();
    </script>
}
