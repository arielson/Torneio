@{
    var slug      = Context.GetRouteData().Values["slug"]?.ToString();
    var anoOrigem = (AnoTorneioDto)ViewBag.AnoOrigem;
    var novoAno   = (int)ViewBag.NovoAno;
    ViewData["Title"] = $"Replicar Ano {anoOrigem.Ano}";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Replicar Ano @anoOrigem.Ano</h1>
    </div>
</div>
<a href="/@slug/anos" class="back-link">
    <i class="bi bi-arrow-left"></i> Anos
</a>

<div class="form-card">
    <div class="alert alert-info d-flex gap-2 align-items-start mb-4 py-2">
        <i class="bi bi-info-circle-fill mt-1"></i>
        <span>
            Será criado um novo ano com os dados de Fiscais, Equipes e Membros do ano <strong>@anoOrigem.Ano</strong>.
            Capturas e sorteios <strong>não</strong> são replicados.
        </span>
    </div>
    <form asp-controller="Ano" asp-action="Replicar" asp-route-slug="@slug" asp-route-id="@anoOrigem.Id" method="post">
        <div class="form-section-title">Configuração</div>
        <div class="mb-3">
            <label class="form-label">Novo Ano</label>
            <input name="novoAno" class="form-control" type="number" min="2000" max="2100" value="@novoAno" />
        </div>
        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-copy me-1"></i>Replicar
            </button>
            <a href="/@slug/anos" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>
