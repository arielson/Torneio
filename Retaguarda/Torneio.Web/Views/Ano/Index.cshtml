@model IEnumerable<AnoTorneioDto>
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    ViewData["Title"] = "Anos";
    var lista = Model.OrderByDescending(x => x.Ano).ToList();
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Edições</h1>
    </div>
    <div class="page-header-actions">
        <a href="/@slug/anos/criar" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nova Edição
        </a>
    </div>
</div>
<a href="/@slug/admin" class="back-link">
    <i class="bi bi-arrow-left"></i> Painel
</a>

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-calendar3 me-2"></i>Anos do Torneio</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">
            Nenhuma edição cadastrada. <a href="/@slug/anos/criar">Criar a primeira</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Ano</th>
                        <th>Status</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in lista)
                    {
                        var badgeClass = a.Status switch
                        {
                            "Liberado"   => "bg-success-subtle text-success border-success-subtle",
                            "Finalizado" => "bg-secondary-subtle text-secondary border-secondary-subtle",
                            _            => "bg-warning-subtle text-warning border-warning-subtle"
                        };
                        <tr>
                            <td class="fw-semibold">@a.Ano</td>
                            <td><span class="badge border @badgeClass">@a.Status</span></td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end flex-wrap">
                                    @if (a.Status == "Aberto")
                                    {
                                        <form asp-controller="Ano" asp-action="Liberar" asp-route-slug="@slug" asp-route-id="@a.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-success">
                                                <i class="bi bi-play-fill me-1"></i>Liberar
                                            </button>
                                        </form>
                                    }
                                    @if (a.Status == "Liberado")
                                    {
                                        <form asp-controller="Ano" asp-action="Finalizar" asp-route-slug="@slug" asp-route-id="@a.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-secondary" onclick="return confirm('Finalizar este ano?')">
                                                <i class="bi bi-check2-all me-1"></i>Finalizar
                                            </button>
                                        </form>
                                    }
                                    @if (a.Status == "Finalizado")
                                    {
                                        <form asp-controller="Ano" asp-action="Reabrir" asp-route-slug="@slug" asp-route-id="@a.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-warning">
                                                <i class="bi bi-arrow-counterclockwise me-1"></i>Reabrir
                                            </button>
                                        </form>
                                    }
                                    <a asp-controller="Ano" asp-action="Replicar" asp-route-slug="@slug" asp-route-id="@a.Id"
                                       class="btn btn-sm btn-outline-secondary" title="Replicar">
                                        <i class="bi bi-copy"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
