@model CriarAnoTorneioDto
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    ViewData["Title"] = "Nova Edição";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Nova Edição</h1>
    </div>
</div>
<a href="/@slug/anos" class="back-link">
    <i class="bi bi-arrow-left"></i> Anos
</a>

<div class="form-card">
    <form asp-controller="Ano" asp-action="Criar" asp-route-slug="@slug" method="post">
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }
        <div class="form-section-title">Dados da Edição</div>
        <div class="mb-3">
            <label asp-for="Ano" class="form-label">Ano</label>
            <input asp-for="Ano" class="form-control" type="number" min="2000" max="2100" value="@DateTime.Now.Year" />
            <span asp-validation-for="Ano" class="text-danger small"></span>
        </div>
        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Criar Edição
            </button>
            <a href="/@slug/anos" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
