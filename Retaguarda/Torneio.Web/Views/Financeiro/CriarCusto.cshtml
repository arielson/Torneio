@model Torneio.Application.DTOs.Financeiro.CriarCustoTorneioDto
@using Torneio.Domain.Enums
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    ViewData["Title"] = "Novo custo";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Novo custo</h1>
    </div>
</div>
<a href="/@slug/financeiro/custos" class="back-link">
    <i class="bi bi-arrow-left"></i> Custos
</a>

<div class="form-card">
    <form asp-controller="Financeiro" asp-action="CriarCusto" asp-route-slug="@slug" method="post">
        <input asp-for="TorneioId" type="hidden" />
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
        }
        <div class="mb-3">
            <label asp-for="Categoria" class="form-label">Categoria</label>
            <select asp-for="Categoria" class="form-select" asp-items="Html.GetEnumSelectList<CategoriaCustoTorneio>()"></select>
        </div>
        <div class="mb-3">
            <label asp-for="Descricao" class="form-label">Descricao</label>
            <input asp-for="Descricao" class="form-control" />
        </div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Quantidade" class="form-label">Quantidade</label>
                <input asp-for="Quantidade" class="form-control" type="number" step="0.01" min="0.01" />
            </div>
            <div class="col-md-6">
                <label asp-for="ValorUnitario" class="form-label">Valor unitario</label>
                <input asp-for="ValorUnitario" class="form-control" type="number" step="0.01" min="0" />
            </div>
        </div>
        <div class="mt-3">
            <label asp-for="Responsavel" class="form-label">Responsavel</label>
            <input asp-for="Responsavel" class="form-control" />
        </div>
        <div class="mt-3">
            <label asp-for="Observacao" class="form-label">Observacao</label>
            <textarea asp-for="Observacao" class="form-control" rows="3"></textarea>
        </div>
        <div class="d-flex gap-2 pt-3">
            <button type="submit" class="btn btn-primary">Salvar custo</button>
            <a href="/@slug/financeiro/custos" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
