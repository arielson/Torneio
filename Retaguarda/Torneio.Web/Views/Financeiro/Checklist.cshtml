@model IEnumerable<Torneio.Application.DTOs.Financeiro.ChecklistTorneioItemDto>
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    ViewData["Title"] = "Checklist";
    var lista = Model.OrderBy(x => x.Concluido).ThenBy(x => x.Data ?? DateTime.MaxValue).ThenBy(x => x.Item).ToList();
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Checklist</h1>
    </div>
    <div class="page-header-actions">
        <a href="/@slug/financeiro/checklist/criar" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Novo item
        </a>
    </div>
</div>
<a href="/@slug/financeiro" class="back-link">
    <i class="bi bi-arrow-left"></i> Financeiro
</a>

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-list-check me-2"></i>Itens do checklist</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">Nenhum item cadastrado.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Data</th>
                        <th>Responsavel</th>
                        <th>Status</th>
                        <th class="text-end">Acoes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in lista)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Item</td>
                            <td>@(item.Data.HasValue ? item.Data.Value.ToString("dd/MM/yyyy") : "-")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Responsavel) ? "-" : item.Responsavel)</td>
                            <td>
                                @if (item.Concluido)
                                {
                                    <span class="badge text-bg-success">Concluido</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-warning">Pendente</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/@slug/financeiro/checklist/@item.Id/editar" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-controller="Financeiro" asp-action="RemoverChecklist" asp-route-slug="@slug" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remover o item de checklist @item.Item?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
