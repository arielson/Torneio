@model Torneio.Application.DTOs.Financeiro.AtualizarDoacaoPatrocinadorDto
@using Torneio.Application.DTOs.Patrocinador
@using Torneio.Domain.Enums
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    var patrocinadores = ((IEnumerable<PatrocinadorDto>)ViewBag.Patrocinadores).OrderBy(x => x.Nome).ToList();
    ViewData["Title"] = "Editar doação";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Editar doação</h1>
    </div>
</div>
<a href="/@slug/financeiro/doacoes" class="back-link">
    <i class="bi bi-arrow-left"></i> Doações
</a>

<div class="form-card">
    <form method="post">
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
        }
        <div class="mb-3">
            <label asp-for="PatrocinadorId" class="form-label">Patrocinador cadastrado</label>
            <select asp-for="PatrocinadorId" class="form-select" id="patrocinadorSelect">
                <option value="">Selecione</option>
                @foreach (var patrocinador in patrocinadores)
                {
                    <option value="@patrocinador.Id">@patrocinador.Nome</option>
                }
            </select>
            <div class="form-text">A doação será vinculada ao patrocinador selecionado.</div>
        </div>
        <div class="mb-3">
            <label asp-for="Tipo" class="form-label">Tipo</label>
            <select asp-for="Tipo" class="form-select" asp-items="Html.GetEnumSelectList<TipoDoacaoPatrocinador>()" id="tipoDoacao"></select>
        </div>
        <div class="mb-3">
            <label asp-for="Descricao" class="form-label">Descrição</label>
            <input asp-for="Descricao" class="form-control" />
        </div>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="DataDoacao" class="form-label">Data</label>
                <input asp-for="DataDoacao" class="form-control" type="date" />
            </div>
            <div class="col-md-4">
                <label asp-for="Quantidade" class="form-label">Quantidade</label>
                <input asp-for="Quantidade" class="form-control" type="number" step="0.01" min="0" />
            </div>
            <div class="col-md-4">
                <label asp-for="Valor" class="form-label">Valor</label>
                <input asp-for="Valor" class="form-control" type="number" step="0.01" min="0" id="valorDoacao" />
                <div class="form-text" id="valorHint">Obrigatório apenas para doações em dinheiro.</div>
            </div>
        </div>
        <div class="mt-3">
            <label asp-for="Observacao" class="form-label">Observação</label>
            <textarea asp-for="Observacao" class="form-control" rows="3"></textarea>
        </div>
        <div class="d-flex gap-2 pt-3">
            <button type="submit" class="btn btn-primary">Salvar alterações</button>
            <a href="/@slug/financeiro/doacoes" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const tipoDoacao = document.getElementById('tipoDoacao');
            const valorDoacao = document.getElementById('valorDoacao');
            const valorHint = document.getElementById('valorHint');

            const atualizarValor = () => {
                const ehDinheiro = (tipoDoacao?.value || '').toLowerCase().includes('dinheiro') || tipoDoacao?.value === '1';
                if (!valorDoacao || !valorHint) return;
                valorDoacao.disabled = !ehDinheiro;
                if (!ehDinheiro) valorDoacao.value = '';
                valorHint.textContent = ehDinheiro
                    ? 'Obrigatório para doações em dinheiro.'
                    : 'Não entra como receita quando a doação for em produto.';
            };

            tipoDoacao?.addEventListener('change', atualizarValor);
            atualizarValor();
        })();
    </script>
}
