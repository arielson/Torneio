@model Torneio.Application.DTOs.Financeiro.CriarProdutoExtraMembroDto
@using Torneio.Application.DTOs.Financeiro
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    var produtos = ((IEnumerable<ProdutoExtraTorneioDto>)ViewBag.Produtos).ToList();
    var produtoSelecionado = ViewBag.ProdutoSelecionado as ProdutoExtraTorneioDto;
    var membros = ((IEnumerable<Torneio.Application.DTOs.Membro.MembroDto>)ViewBag.Membros).OrderBy(x => x.Nome).ToList();
    var vendas = ((IEnumerable<ProdutoExtraMembroDto>)ViewBag.Vendas).ToList();
    ViewData["Title"] = "Registrar venda";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Registrar venda</h1>
    </div>
</div>
<a href="/@slug/financeiro/extras" class="back-link">
    <i class="bi bi-arrow-left"></i> Produtos extras
</a>

<div class="content-card mb-4">
    <div class="card-header-bar">
        <h5><i class="bi bi-cart-plus me-2"></i>Nova venda</h5>
    </div>
    <div class="card-body-pad">
        @if (!produtos.Any())
        {
            <div class="text-muted">Cadastre ao menos um produto extra para registrar vendas.</div>
        }
        else
        {
            <form method="post" class="row g-3 align-items-end">
                @Html.AntiForgeryToken()
                <input asp-for="TorneioId" type="hidden" />
                <div class="col-md-4">
                    <label class="form-label">Produto extra</label>
                    <select asp-for="ProdutoExtraTorneioId" class="form-select" id="produtoExtraId" required>
                        <option value="">Selecione</option>
                        @foreach (var produto in produtos)
                        {
                            <option value="@produto.Id" data-valor="@produto.Valor.ToString(System.Globalization.CultureInfo.InvariantCulture)" selected="@(produto.Id == Model.ProdutoExtraTorneioId ? "selected" : null)">@produto.Nome</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Pescador</label>
                    <select asp-for="MembroId" class="form-select" required>
                        <option value="">Selecione</option>
                        @foreach (var membro in membros)
                        {
                            <option value="@membro.Id">@membro.Nome</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Quantidade</label>
                    <input asp-for="Quantidade" id="quantidadeVenda" class="form-control" type="number" step="0.01" min="0.01" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Valor total</label>
                    <input asp-for="ValorCobrado" id="valorCobradoVenda" class="form-control" type="number" step="0.01" readonly />
                </div>
                <div class="col-md-9">
                    <label asp-for="Observacao" class="form-label">Observacao</label>
                    <input asp-for="Observacao" class="form-control" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">Registrar venda</button>
                </div>
            </form>
        }
    </div>
</div>

@if (produtoSelecionado is not null)
{
    <div class="content-card">
        <div class="card-header-bar">
            <h5><i class="bi bi-receipt me-2"></i>Vendas de @produtoSelecionado.Nome</h5>
        </div>
        @if (!vendas.Any())
        {
            <div class="card-body-pad text-muted">Nenhuma venda registrada para este produto extra.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Pescador</th>
                            <th>Quantidade</th>
                            <th>Valor</th>
                            <th>Status</th>
                            <th class="text-end">Acoes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in vendas)
                        {
                            <tr class="@(item.Pago ? "table-success" : item.Inadimplente ? "table-danger" : string.Empty)">
                                <td class="fw-semibold">@item.NomeMembro</td>
                                <td>@item.Quantidade.ToString("N2")</td>
                                <td>R$ @item.ValorCobrado.ToString("N2")</td>
                                <td>
                                    @if (item.Pago)
                                    {
                                        <span class="badge text-bg-success">Pago</span>
                                    }
                                    else if (item.Inadimplente)
                                    {
                                        <span class="badge text-bg-danger">Inadimplente</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-warning">Em aberto</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        @if (item.ParcelaId.HasValue)
                                        {
                                            <a href="/@slug/financeiro/cobrancas/@item.ParcelaId.Value/editar" class="btn btn-sm btn-outline-secondary">Cobranca</a>
                                        }
                                        <form asp-action="RemoverExtraMembro" asp-route-slug="@slug" asp-route-produtoExtraMembroId="@item.Id" asp-route-produtoId="@produtoSelecionado.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remover esta venda?')">Remover</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        (() => {
            const produtoSelect = document.getElementById('produtoExtraId');
            const quantidadeInput = document.getElementById('quantidadeVenda');
            const valorInput = document.getElementById('valorCobradoVenda');

            const valorUnitarioAtual = () => {
                const option = produtoSelect?.selectedOptions?.[0];
                return option ? Number.parseFloat(option.dataset.valor || '0') : 0;
            };

            const atualizarValor = () => {
                if (!quantidadeInput || !valorInput) return;
                const quantidade = Number.parseFloat(quantidadeInput.value || '0');
                const total = valorUnitarioAtual() * (Number.isFinite(quantidade) ? quantidade : 0);
                valorInput.value = total.toFixed(2);
            };

            produtoSelect?.addEventListener('change', () => {
                atualizarValor();
                const id = produtoSelect.value;
                if (id) {
                    window.location.href = `/${@Html.Raw(System.Text.Json.JsonSerializer.Serialize(slug))}/financeiro/extras/vendas?produtoId=${id}`;
                }
            });
            quantidadeInput?.addEventListener('input', atualizarValor);
            atualizarValor();
        })();
    </script>
}
