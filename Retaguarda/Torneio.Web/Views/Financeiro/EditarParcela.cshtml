@model Torneio.Application.DTOs.Financeiro.ParcelaTorneioDto
@using Torneio.Application.DTOs.Financeiro
@using Torneio.Application.DTOs.Asaas
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    ViewData["Title"] = $"Cobranca {Model.NumeroParcela} - {Model.NomeMembro}";
    var torneio = (TorneioDto)ViewBag.Torneio;
    var labelMembro = torneio?.LabelMembro ?? "Membro";
    var doacoes = ((IEnumerable<DoacaoPatrocinadorDto>?)ViewBag.Doacoes ?? Enumerable.Empty<DoacaoPatrocinadorDto>()).OrderBy(x => x.NomePatrocinador).ToList();
    var cobrancaAsaas = ViewBag.CobrancaAsaas as CobrancaAsaasDto;
    var configAsaas = ViewBag.ConfigAsaas as ConfiguracaoAsaasDto;
    var membroCelular = ViewBag.MembroCelular as string;
    var celularDigitos = string.IsNullOrWhiteSpace(membroCelular)
        ? null
        : new string(membroCelular.Where(char.IsDigit).ToArray());
    // garante prefixo 55 para WhatsApp (E.164 sem +)
    var celularWa = celularDigitos is { Length: >= 10 }
        ? (celularDigitos.StartsWith("55") ? celularDigitos : "55" + celularDigitos)
        : null;

    var cobrancaAtiva = cobrancaAsaas is not null &&
        cobrancaAsaas.Status is not ("Excluido" or "Estornado" or "RecusadoCartao");
    var invoiceUrl    = cobrancaAsaas?.AsaasInvoiceUrl ?? "";
    var membroTemCpf  = ViewBag.MembroTemCpf as bool? ?? false;
    var taxaPix       = ViewBag.TaxaPix    is decimal tp ? tp : (decimal?)null;
    var taxaCartao    = ViewBag.TaxaCartao is decimal tc ? tc : (decimal?)null;
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Cobranca @Model.NumeroParcela - @Model.NomeMembro</h1>
    </div>
</div>
<a href="/@slug/financeiro/cobrancas" class="back-link">
    <i class="bi bi-arrow-left"></i> Cobranças
</a>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="content-card h-100">
            <div class="card-header-bar">
                <h5><i class="bi bi-info-circle me-2"></i>Resumo</h5>
            </div>
            <div class="card-body-pad">
                <dl class="row mb-0">
                    <dt class="col-5">@labelMembro</dt><dd class="col-7">@Model.NomeMembro</dd>
                    <dt class="col-5">Parcela</dt><dd class="col-7">@Model.NumeroParcela</dd>
                    <dt class="col-5">Valor</dt><dd class="col-7">R$ @Model.Valor.ToString("N2")</dd>
                    <dt class="col-5">Vencimento</dt><dd class="col-7">@Model.Vencimento.ToString("dd/MM/yyyy")</dd>
                    <dt class="col-5">Status</dt>
                    <dd class="col-7">
                        @if (Model.Pago)
                        {
                            <span class="badge text-bg-success">Pago</span>
                        }
                        else if (Model.Bonificada)
                        {
                            <span class="badge text-bg-info">Bonificada</span>
                        }
                        else if (Model.Inadimplente)
                        {
                            <span class="badge text-bg-danger">Inadimplente</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">Em aberto</span>
                        }
                    </dd>
                    @if (Model.Bonificada)
                    {
                        <dt class="col-5">Bonificação</dt>
                        <dd class="col-7">
                            @if (!string.IsNullOrWhiteSpace(Model.MotivoBonificacao))
                            {
                                <span>@Model.MotivoBonificacao</span>
                                <br />
                            }
                            @if (Model.DoacaoPatrocinadorId.HasValue)
                            {
                                var doacao = doacoes.FirstOrDefault(d => d.Id == Model.DoacaoPatrocinadorId);
                                if (doacao is not null)
                                {
                                    <span class="text-muted small">Doação: @doacao.NomePatrocinador — @doacao.Descricao (@doacao.DataDoacao.ToString("dd/MM/yyyy"))</span>
                                }
                            }
                        </dd>
                    }
                    <dt class="col-5">Comprovante</dt>
                    <dd class="col-7">
                        @if (!string.IsNullOrWhiteSpace(Model.ComprovanteUrl))
                        {
                            <a href="@Model.ComprovanteUrl" target="_blank" rel="noopener noreferrer">Visualizar arquivo</a>
                            <div class="small text-muted">@Model.ComprovanteNomeArquivo</div>
                        }
                        else
                        {
                            <span class="text-muted">Nenhum comprovante anexado.</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="content-card mb-3">
            <div class="card-header-bar">
                <h5><i class="bi bi-calendar-event me-2"></i>Dados da cobrança</h5>
            </div>
            <div class="card-body-pad">
                <form asp-controller="Financeiro" asp-action="EditarCobranca" asp-route-slug="@slug" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Vencimento</label>
                        <input class="form-control" type="date" name="Vencimento" value="@Model.Vencimento.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Observacao</label>
                        <textarea class="form-control" rows="3" name="Observacao">@Model.Observacao</textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Salvar cobrança
                    </button>
                </form>
            </div>
        </div>

        <div class="content-card mb-3">
            <div class="card-header-bar">
                <h5><i class="bi bi-cash-coin me-2"></i>Pagamento</h5>
            </div>
            <div class="card-body-pad">
                <form asp-controller="Financeiro" asp-action="PagamentoCobranca" asp-route-slug="@slug" asp-route-id="@Model.Id" method="post" class="row g-3 align-items-end">
                    @Html.AntiForgeryToken()
                    <div class="col-md-4">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" id="Pago" name="Pago" value="true" checked="@Model.Pago" />
                            <label class="form-check-label" for="Pago">Pago</label>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Data de pagamento</label>
                        <input class="form-control" type="date" name="DataPagamento" value="@(Model.DataPagamento?.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-success w-100">Salvar</button>
                    </div>
                </form>
                <div class="form-text mt-2">Ao desmarcar o pagamento, a data de pagamento e limpa para manter a consistência do estado.</div>
            </div>
        </div>

        <div class="content-card mb-3">
            <div class="card-header-bar">
                <h5><i class="bi bi-paperclip me-2"></i>Comprovante</h5>
            </div>
            <div class="card-body-pad">
                <form asp-controller="Financeiro" asp-action="UploadComprovanteCobranca" asp-route-slug="@slug" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Arquivo</label>
                        <input class="form-control" type="file" name="arquivo" />
                    </div>
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-upload me-1"></i>Enviar comprovante
                    </button>
                </form>
            </div>
        </div>

        <div class="content-card mb-3">
            <div class="card-header-bar">
                <h5><i class="bi bi-credit-card-2-front me-2"></i>Cobrança Asaas</h5>
            </div>
            <div class="card-body-pad">
                @if (cobrancaAsaas is not null)
                {
                    <dl class="row mb-3">
                        <dt class="col-5">Status</dt>
                        <dd class="col-7">
                            @{
                                var badgeCls = cobrancaAsaas.Status switch {
                                    "Confirmado" or "Recebido" => "bg-success",
                                    "Excluido" or "Estornado" or "RecusadoCartao" => "bg-danger",
                                    "Vencido" => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeCls">@cobrancaAsaas.Status</span>
                        </dd>
                        <dt class="col-5">Forma</dt>
                        <dd class="col-7">@(cobrancaAsaas.FormaPagamento ?? "—")</dd>
                        <dt class="col-5">Valor da parcela</dt>
                        <dd class="col-7">R$ @cobrancaAsaas.ValorOriginal.ToString("N2")</dd>
                        @if (cobrancaAsaas.TaxaAsaas.HasValue)
                        {
                            <dt class="col-5">Taxa Asaas</dt>
                            <dd class="col-7">R$ @cobrancaAsaas.TaxaAsaas.Value.ToString("N2")</dd>
                            <dt class="col-5">Total cobrado</dt>
                            <dd class="col-7">R$ @((cobrancaAsaas.ValorOriginal + cobrancaAsaas.TaxaAsaas.Value).ToString("N2"))</dd>
                            <dt class="col-5">Valor líquido</dt>
                            <dd class="col-7">R$ @cobrancaAsaas.ValorOriginal.ToString("N2")</dd>
                        }
                        @if (cobrancaAsaas.DataPrevisaoCredito.HasValue)
                        {
                            <dt class="col-5">Previsão crédito</dt>
                            <dd class="col-7">@cobrancaAsaas.DataPrevisaoCredito.Value.ToString("dd/MM/yyyy")</dd>
                        }
                        @if (cobrancaAsaas.DataCreditoEfetivo.HasValue)
                        {
                            <dt class="col-5">Crédito efetivo</dt>
                            <dd class="col-7">@cobrancaAsaas.DataCreditoEfetivo.Value.ToString("dd/MM/yyyy")</dd>
                        }
                        <dt class="col-5">Payment ID</dt>
                        <dd class="col-7 text-muted small font-monospace">@cobrancaAsaas.AsaasPaymentId</dd>
                    </dl>

                    <div class="d-flex gap-2 flex-wrap">
                        @if (!string.IsNullOrEmpty(cobrancaAsaas.AsaasInvoiceUrl))
                        {
                            <a href="@cobrancaAsaas.AsaasInvoiceUrl" target="_blank" rel="noopener"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-box-arrow-up-right me-1"></i>Link da fatura
                            </a>
                        }
                        @if (cobrancaAsaas.FormaPagamento == "Pix" &&
                             cobrancaAsaas.Status is "Pendente" or "Vencido")
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    onclick="carregarQrCode('@Model.Id', '@slug')">
                                <i class="bi bi-qr-code me-1"></i>Ver QR Code PIX
                            </button>
                        }
                        @if (cobrancaAsaas.Status is "Pendente" or "Vencido")
                        {
                            <form asp-controller="CobrancaAsaas"
                                  asp-action="Cancelar"
                                  asp-route-slug="@slug"
                                  asp-route-parcelaId="@Model.Id"
                                  method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Cancelar esta cobrança no Asaas?')">
                                    <i class="bi bi-x-circle me-1"></i>Cancelar cobrança
                                </button>
                            </form>
                        }
                    </div>

                    <!-- Modal QR Code PIX -->
                    <div class="modal fade" id="modalQrCode" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title"><i class="bi bi-qr-code me-2"></i>QR Code PIX</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body text-center" id="qrCodeContent">
                                    <div class="spinner-border text-secondary" role="status"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else if (configAsaas?.StatusChave == "Ativa")
                {
                    <p class="text-muted small mb-3">Nenhuma cobrança Asaas gerada para esta parcela.</p>

                    @* Prévia de taxas antes de gerar *@
                    @if (taxaPix.HasValue || taxaCartao.HasValue)
                    {
                        <dl class="row mb-3 small">
                            @if (configAsaas.AceitarPix && taxaPix.HasValue)
                            {
                                <dt class="col-6 text-muted">PIX — taxa</dt>
                                <dd class="col-6">R$ @taxaPix.Value.ToString("N2")</dd>
                                <dt class="col-6 text-muted">PIX — total cobrado</dt>
                                <dd class="col-6 fw-semibold">R$ @((Model.Valor + taxaPix.Value).ToString("N2"))</dd>
                            }
                            @if (configAsaas.AceitarCartaoCredito && taxaCartao.HasValue)
                            {
                                <dt class="col-6 text-muted">Cartão — taxa</dt>
                                <dd class="col-6">R$ @taxaCartao.Value.ToString("N2")</dd>
                                <dt class="col-6 text-muted">Cartão — total cobrado</dt>
                                <dd class="col-6 fw-semibold">R$ @((Model.Valor + taxaCartao.Value).ToString("N2"))</dd>
                            }
                        </dl>
                    }

                    @if (!membroTemCpf)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">
                                CPF do @labelMembro.ToLower()
                                <span class="text-danger">*</span>
                                <span class="text-muted fw-normal">(exigido pelo Asaas)</span>
                            </label>
                            <input type="text" id="inputCpfAsaas" class="form-control form-control-sm"
                                   placeholder="000.000.000-00" inputmode="numeric" maxlength="14" />
                        </div>
                    }

                    <div class="d-flex gap-2 flex-wrap">
                        @if (configAsaas.AceitarPix)
                        {
                            <form asp-controller="CobrancaAsaas"
                                  asp-action="Gerar"
                                  asp-route-slug="@slug"
                                  asp-route-parcelaId="@Model.Id"
                                  method="post" class="d-inline form-gerar-asaas">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="formaPagamento" value="0" />
                                <input type="hidden" name="cpf" class="cpf-hidden" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-qr-code me-1"></i>Gerar cobrança PIX
                                </button>
                            </form>
                        }
                        @if (configAsaas.AceitarCartaoCredito)
                        {
                            <form asp-controller="CobrancaAsaas"
                                  asp-action="Gerar"
                                  asp-route-slug="@slug"
                                  asp-route-parcelaId="@Model.Id"
                                  method="post" class="d-inline form-gerar-asaas">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="formaPagamento" value="1" />
                                <input type="hidden" name="cpf" class="cpf-hidden" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-credit-card me-1"></i>Gerar cobrança Cartão
                                </button>
                            </form>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Integração Asaas não configurada para este torneio.
                        Configure em <a href="/admin/asaas">Integrações Asaas</a>.
                    </p>
                }
            </div>
        </div>

        @if (cobrancaAtiva && !string.IsNullOrEmpty(invoiceUrl))
        {
            <div class="content-card mb-3">
                <div class="card-header-bar">
                    <h5><i class="bi bi-share me-2"></i>Compartilhar com o @labelMembro.ToLower()</h5>
                </div>
                <div class="card-body-pad">
                    <p class="text-muted small mb-3">
                        Envie o link abaixo para o @labelMembro.ToLower() efetuar o pagamento pelo celular.
                    </p>

                    @* Link copiável *@
                    <div class="input-group mb-3">
                        <input type="text" id="linkPagamento" class="form-control form-control-sm font-monospace"
                               value="@invoiceUrl" readonly />
                        <button class="btn btn-outline-secondary btn-sm" type="button"
                                onclick="navigator.clipboard.writeText(document.getElementById('linkPagamento').value).then(()=>{this.innerHTML='<i class=\'bi bi-check-lg\'></i> Copiado!';setTimeout(()=>this.innerHTML='<i class=\'bi bi-clipboard\'></i> Copiar',2000)})">
                            <i class="bi bi-clipboard"></i> Copiar
                        </button>
                    </div>

                    @* WhatsApp *@
                    @if (celularWa is not null)
                    {
                        var msg = Uri.EscapeDataString(
                            $"Olá {Model.NomeMembro}! Segue o link para pagamento da sua cobrança: {invoiceUrl}");
                        <a href="https://wa.me/@celularWa?text=@msg" target="_blank" rel="noopener"
                           class="btn btn-success me-2">
                            <i class="bi bi-whatsapp me-1"></i>Enviar via WhatsApp
                        </a>
                    }
                    else
                    {
                        <span class="text-muted small">
                            <i class="bi bi-whatsapp me-1"></i>
                            Celular não cadastrado — cadastre o celular do @labelMembro.ToLower() para enviar via WhatsApp.
                        </span>
                    }

                    @* QR Code PIX inline *@
                    @if (cobrancaAsaas?.FormaPagamento == "Pix" &&
                         cobrancaAsaas.Status is "Pendente" or "Vencido")
                    {
                        <div class="mt-4">
                            <button type="button" class="btn btn-outline-primary btn-sm"
                                    id="btnQrInline"
                                    onclick="carregarQrCodeInline('@Model.Id', '@slug')">
                                <i class="bi bi-qr-code me-1"></i>Mostrar QR Code na tela
                            </button>
                            <div id="qrInlineContainer" class="mt-3 text-center d-none">
                                <div id="qrInlineContent">
                                    <div class="spinner-border text-secondary" role="status"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="content-card">
            <div class="card-header-bar">
                <h5><i class="bi bi-gift me-2"></i>Bonificação por doação</h5>
            </div>
            <div class="card-body-pad">
                @if (Model.Bonificada)
                {
                    <p class="text-muted small mb-3">Esta cobrança está marcada como bonificada. Ela não entra como receita nas apurações financeiras.</p>
                    <form asp-controller="Financeiro" asp-action="DesmarcarBonificacaoCobranca" asp-route-slug="@slug" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger"
                                onclick="return confirm('Remover a bonificação desta cobrança?')">
                            <i class="bi bi-x-circle me-1"></i>Remover bonificação
                        </button>
                    </form>
                }
                else if (Model.Pago)
                {
                    <p class="text-muted small mb-0">Não é possível bonificar uma cobrança já paga.</p>
                }
                else
                {
                    <p class="text-muted small mb-3">Marque como bonificada quando a cobrança for coberta por uma doação de patrocinador. A parcela não entrará como receita nas apurações.</p>
                    <form asp-controller="Financeiro" asp-action="BonificarCobranca" asp-route-slug="@slug" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Doação vinculada <span class="text-muted fw-normal">(opcional)</span></label>
                            <select class="form-select" name="DoacaoPatrocinadorId">
                                <option value="">Nenhuma doação vinculada</option>
                                @foreach (var doacao in doacoes)
                                {
                                    <option value="@doacao.Id">@doacao.NomePatrocinador — @doacao.Descricao (@doacao.DataDoacao.ToString("dd/MM/yyyy"))</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Motivo <span class="text-muted fw-normal">(opcional)</span></label>
                            <input class="form-control" type="text" name="MotivoBonificacao" maxlength="500"
                                   placeholder="Ex.: Empresa do participante doou equipamentos ao torneio" />
                        </div>
                        <button type="submit" class="btn btn-info text-white">
                            <i class="bi bi-gift me-1"></i>Marcar como bonificada
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Máscara de CPF e cópia para os hidden fields antes de submeter
(function () {
    var cpfInput = document.getElementById('inputCpfAsaas');
    if (!cpfInput) return;

    cpfInput.addEventListener('input', function () {
        var d = this.value.replace(/\D/g, '').substring(0, 11);
        var f = '';
        if (d.length <= 3)       f = d;
        else if (d.length <= 6)  f = d.slice(0,3)+'.'+d.slice(3);
        else if (d.length <= 9)  f = d.slice(0,3)+'.'+d.slice(3,6)+'.'+d.slice(6);
        else                      f = d.slice(0,3)+'.'+d.slice(3,6)+'.'+d.slice(6,9)+'-'+d.slice(9);
        this.value = f;
    });

    document.querySelectorAll('.form-gerar-asaas').forEach(function (form) {
        form.addEventListener('submit', function () {
            var digits = cpfInput.value.replace(/\D/g, '');
            if (digits.length !== 11) {
                cpfInput.focus();
                cpfInput.classList.add('is-invalid');
                event.preventDefault();
                return;
            }
            form.querySelector('.cpf-hidden').value = cpfInput.value;
        });
    });
})();

async function carregarQrCodeInline(parcelaId, slug) {
    const container = document.getElementById('qrInlineContainer');
    const content   = document.getElementById('qrInlineContent');
    const btn       = document.getElementById('btnQrInline');
    container.classList.remove('d-none');
    btn.classList.add('d-none');

    try {
        const resp = await fetch(`/${slug}/financeiro/asaas/${parcelaId}/qrcode`);
        const json = await resp.json();

        if (json.success) {
            const { encodedImage, payload } = json.data;
            content.innerHTML = `
                <img src="data:image/png;base64,${encodedImage}" alt="QR Code PIX"
                     style="max-width:220px;" class="mb-3 d-block mx-auto border rounded p-2" />
                <p class="small text-muted mb-1">Copia e cola:</p>
                <div class="input-group input-group-sm mb-2 mx-auto" style="max-width:400px">
                    <input type="text" class="form-control font-monospace small"
                           value="${payload}" readonly />
                    <button class="btn btn-outline-secondary" type="button"
                            onclick="navigator.clipboard.writeText('${payload}').then(()=>this.textContent='Copiado!')">
                        Copiar
                    </button>
                </div>`;
        } else {
            content.innerHTML = `<p class="text-danger">${json.error}</p>`;
        }
    } catch {
        content.innerHTML = '<p class="text-danger">Erro ao carregar QR Code.</p>';
    }
}

async function carregarQrCode(parcelaId, slug) {
    const modal = new bootstrap.Modal(document.getElementById('modalQrCode'));
    const content = document.getElementById('qrCodeContent');
    content.innerHTML = '<div class="spinner-border text-secondary" role="status"></div>';
    modal.show();

    try {
        const resp = await fetch(`/${slug}/financeiro/asaas/${parcelaId}/qrcode`);
        const json = await resp.json();

        if (json.success) {
            const { encodedImage, payload } = json.data;
            content.innerHTML = `
                <img src="data:image/png;base64,${encodedImage}" alt="QR Code PIX"
                     style="max-width:260px;" class="mb-3 d-block mx-auto" />
                <p class="small text-muted mb-1">Copia e cola:</p>
                <div class="input-group input-group-sm mb-2">
                    <input type="text" class="form-control font-monospace small" id="pixPayload"
                           value="${payload}" readonly />
                    <button class="btn btn-outline-secondary" type="button"
                            onclick="navigator.clipboard.writeText('${payload}').then(()=>this.textContent='Copiado!')">
                        Copiar
                    </button>
                </div>`;
        } else {
            content.innerHTML = `<p class="text-danger">${json.error}</p>`;
        }
    } catch {
        content.innerHTML = '<p class="text-danger">Erro ao carregar QR Code.</p>';
    }
}
</script>
}
