@model Torneio.Web.Models.EditarDadosTorneioAdminViewModel
@{
    ViewData["Title"] = "Editar Dados do Torneio";
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Editar Dados do Torneio</h1>
    </div>
</div>

<a href="/@slug/admin" class="back-link">
    <i class="bi bi-arrow-left"></i> Voltar ao painel
</a>

<div class="form-card">
    <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }

        <div class="form-section-title">Identificacao</div>
        <div class="mb-3">
            <label asp-for="NomeTorneio" class="form-label">Nome</label>
            <input asp-for="NomeTorneio" class="form-control" />
            <span asp-validation-for="NomeTorneio" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Descricao" class="form-label">Descricao</label>
            <textarea asp-for="Descricao" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Descricao" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="ObservacoesInternas" class="form-label">Observacoes Internas</label>
            <textarea asp-for="ObservacoesInternas" class="form-control" rows="4"></textarea>
            <div class="form-text">Campo interno. Nao e exibido publicamente.</div>
            <span asp-validation-for="ObservacoesInternas" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Logo</label>
            @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
            {
                <div class="mb-2">
                    <img src="@Model.LogoUrl" alt="Logo atual" style="max-height:80px;max-width:160px;border-radius:6px;border:1px solid #dee2e6;object-fit:contain;" />
                </div>
            }
            <input asp-for="LogoArquivo" type="file" class="form-control" accept="image/*" />
            <input asp-for="LogoUrl" type="hidden" />
        </div>

        <div class="form-section-title">Configuracoes</div>
        <div class="mb-3">
            <label asp-for="QtdGanhadores" class="form-label">Quantidade de Ganhadores</label>
            <input asp-for="QtdGanhadores" class="form-control" type="number" min="1" max="100" />
            <span asp-validation-for="QtdGanhadores" class="text-danger small"></span>
        </div>
        <div class="form-check mb-2">
            <input asp-for="UsarFatorMultiplicador" class="form-check-input" />
            <label asp-for="UsarFatorMultiplicador" class="form-check-label">Usar Fator Multiplicador</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="PermitirCapturaOffline" class="form-check-input" />
            <label asp-for="PermitirCapturaOffline" class="form-check-label">Permitir Captura Offline</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="ExibirModuloFinanceiro" class="form-check-input" />
            <label asp-for="ExibirModuloFinanceiro" class="form-check-label">Exibir Modulo Financeiro</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="ExibirParticipantesPublicos" class="form-check-input" />
            <label asp-for="ExibirParticipantesPublicos" class="form-check-label">Exibir participantes na tela inicial publica do torneio</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="PremiacaoPorEquipe" class="form-check-input" />
            <label asp-for="PremiacaoPorEquipe" class="form-check-label">Premiar por Embarcacoes (ranking de equipes)</label>
        </div>
        <div class="form-check mb-2">
            <input asp-for="PremiacaoPorMembro" class="form-check-input" />
            <label asp-for="PremiacaoPorMembro" class="form-check-label">Premiar por Pescadores (ranking individual)</label>
        </div>
        <div class="form-check mb-3">
            <input asp-for="ApenasMaiorCapturaPorPescador" class="form-check-input" />
            <label asp-for="ApenasMaiorCapturaPorPescador" class="form-check-label">
                Apenas a maior captura por pescador no ranking
                <small class="text-muted d-block">Quando ativado, cada pescador contribui somente com sua melhor captura. Uma nova captura maior substitui a anterior.</small>
            </label>
        </div>

        <div class="form-section-title">Tema Visual</div>
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="CorPrimaria" class="form-label">Cor Primaria</label>
                <div class="input-group">
                    <input asp-for="CorPrimaria" type="color" class="form-control form-control-color"
                           value="@(Model.CorPrimaria ?? "#106962")" style="max-width:56px;"
                           oninput="document.getElementById('CorPrimariaHex').value=this.value" />
                    <input id="CorPrimariaHex" class="form-control" value="@(Model.CorPrimaria ?? "")"
                           maxlength="7" placeholder="#106962"
                           oninput="document.getElementById('CorPrimaria').value=this.value" />
                </div>
                <span asp-validation-for="CorPrimaria" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Salvar Alteracoes
            </button>
            <a href="/@slug/admin" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
