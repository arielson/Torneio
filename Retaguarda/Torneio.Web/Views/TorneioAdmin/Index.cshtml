@model TorneioDto
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    ViewData["Title"] = Model.NomeTorneio;

    var badgeClass = Model.Status switch
    {
        "Liberado"   => "bg-success-subtle text-success border-success-subtle",
        "Finalizado" => "bg-secondary-subtle text-secondary border-secondary-subtle",
        _            => "bg-warning-subtle text-warning border-warning-subtle"
    };
    var exibirSorteio = !string.Equals(Model.ModoSorteio, "Nenhum", StringComparison.OrdinalIgnoreCase);
    var exibirFinanceiro = Model.ExibirModuloFinanceiro;
}

<div class="page-header">
    <div class="page-header-left">
        <h1>@Model.NomeTorneio</h1>
        <span class="badge border @badgeClass ms-2">@Model.Status</span>
    </div>
    <div class="page-header-actions">
        <a href="/@slug/admin/clonar" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-copy me-1"></i>Clonar
        </a>
    </div>
</div>

<!-- Status actions -->
<div class="content-card mb-4">
    <div class="card-header-bar">
        <h5><i class="bi bi-toggles me-2"></i>Status do Torneio</h5>
    </div>
    <div class="card-body-pad d-flex gap-2 flex-wrap align-items-center">
        @if (TempData["Sucesso"] is string sucesso)
        {
            <div class="alert alert-success py-2 px-3 mb-0 w-100">@sucesso</div>
        }
        @if (TempData["Erro"] is string erro)
        {
            <div class="alert alert-danger py-2 px-3 mb-0 w-100">@erro</div>
        }

        @if (Model.Status == "Aberto")
        {
            <form method="post" action="/@slug/admin/liberar">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-play-circle me-1"></i>Liberar Torneio
                </button>
            </form>
        }
        else if (Model.Status == "Liberado")
        {
            <form method="post" action="/@slug/admin/reabrir">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Voltar para Aberto
                </button>
            </form>
            <form method="post" action="/@slug/admin/finalizar">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-secondary">
                    <i class="bi bi-check2-all me-1"></i>Finalizar Torneio
                </button>
            </form>
        }
        else if (Model.Status == "Finalizado")
        {
            <form method="post" action="/@slug/admin/reabrir">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reabrir Torneio
                </button>
            </form>
        }
    </div>
</div>

<!-- Quick actions -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <a href="/@slug/equipes" class="action-card">
            <div class="action-icon green"><i class="bi bi-people"></i></div>
            <div>
                <div class="action-label">@Model.LabelEquipePlural</div>
                <div class="action-desc">Cadastrar e editar</div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a href="/@slug/fiscais" class="action-card">
            <div class="action-icon blue"><i class="bi bi-person-badge"></i></div>
            <div>
                <div class="action-label">@Model.LabelSupervisorPlural</div>
                <div class="action-desc">Cadastrar e editar</div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a href="/@slug/membros" class="action-card">
            <div class="action-icon teal"><i class="bi bi-person"></i></div>
            <div>
                <div class="action-label">@Model.LabelMembroPlural</div>
                <div class="action-desc">Cadastrar e editar</div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a href="/@slug/itens" class="action-card">
            <div class="action-icon amber"><i class="bi bi-collection"></i></div>
            <div>
                <div class="action-label">@Model.LabelItemPlural</div>
                <div class="action-desc">Cadastrar e editar</div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a href="/@slug/patrocinadores" class="action-card">
            <div class="action-icon blue"><i class="bi bi-megaphone"></i></div>
            <div>
                <div class="action-label">Patrocinadores</div>
                <div class="action-desc">Cadastrar e editar</div>
            </div>
        </a>
    </div>
    @if (exibirFinanceiro)
    {
        <div class="col-md-3 col-sm-6">
            <a href="/@slug/financeiro" class="action-card">
                <div class="action-icon gray"><i class="bi bi-cash-coin"></i></div>
                <div>
                    <div class="action-label">Financeiro</div>
                    <div class="action-desc">Cobranças, custos e checklist</div>
                </div>
            </a>
        </div>
    }
    <div class="col-md-3 col-sm-6">
        <a href="/@slug/capturas" class="action-card">
            <div class="action-icon teal"><i class="bi bi-camera"></i></div>
            <div>
                <div class="action-label">@Model.LabelCapturaPlural</div>
                <div class="action-desc">Visualizar e remover</div>
            </div>
        </a>
    </div>
    @if (exibirSorteio)
    {
        <div class="col-md-3 col-sm-6">
            <a href="/@slug/sorteio" class="action-card">
                <div class="action-icon purple"><i class="bi bi-shuffle"></i></div>
                <div>
                    <div class="action-label">Sorteio</div>
                    <div class="action-desc">Gerenciar sorteio</div>
                </div>
            </a>
        </div>
    }
    <div class="col-md-3 col-sm-6">
        <a href="/@slug/premios" class="action-card">
            <div class="action-icon amber"><i class="bi bi-trophy"></i></div>
            <div>
                <div class="action-label">Prêmios</div>
                <div class="action-desc">Gerenciar premiação</div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a href="/@slug/relatorios" class="action-card">
            <div class="action-icon gray"><i class="bi bi-file-earmark-bar-graph"></i></div>
            <div>
                <div class="action-label">Relatórios</div>
                <div class="action-desc">Gerar PDFs</div>
            </div>
        </a>
    </div>
    @if (exibirSorteio)
    {
        <div class="col-md-3 col-sm-6">
            <a href="/@slug/equipes/reorganizacao-emergencial" class="action-card">
                <div class="action-icon red"><i class="bi bi-exclamation-triangle"></i></div>
                <div>
                    <div class="action-label">Reorganização Emergencial</div>
                    <div class="action-desc">Uso somente em casos extremos</div>
                </div>
            </a>
        </div>
    }
</div>
