@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    ViewData["Title"] = "Clonar Torneio";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Clonar Torneio</h1>
    </div>
</div>

@if (TempData["Erro"] is string erro)
{
    <div class="alert alert-danger">@erro</div>
}

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-copy me-2"></i>Novo Torneio a partir desta Edição</h5>
    </div>
    <div class="card-body-pad">
        <p class="text-muted mb-4">
            Cria um novo torneio copiando fiscais, equipes, membros, itens e prêmios.
            Capturas e sorteios <strong>não</strong> são copiados.
        </p>
        <form method="post" action="/@slug/admin/clonar">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-semibold">Slug do novo torneio</label>
                <input type="text" name="novoSlug" class="form-control" required
                       placeholder="ex: pescaria2026" pattern="^[a-z0-9\-]+$"
                       title="Somente letras minúsculas, números e hífens" />
                <div class="form-text">Será usado na URL: torneio.ari.net.br/<em>slug</em></div>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Nome do novo torneio</label>
                <input type="text" name="novoNome" class="form-control" required
                       placeholder="ex: Amigos da Pesca 2026" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-copy me-1"></i>Clonar
                </button>
                <a href="/@slug/admin" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
