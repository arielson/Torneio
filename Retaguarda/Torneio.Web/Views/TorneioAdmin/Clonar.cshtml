@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    ViewData["Title"] = "Clonar Torneio";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Clonar Torneio</h1>
    </div>
</div>

@if (TempData["Erro"] is string erro)
{
    <div class="alert alert-danger">@erro</div>
}

<div class="content-card">
    <div class="card-header-bar">
        <h5><i class="bi bi-copy me-2"></i>Novo Torneio a partir desta Edicao</h5>
    </div>
    <div class="card-body-pad">
        <p class="text-muted mb-4">
            Esta operacao cria um novo torneio com base no torneio atual, reaproveitando a estrutura cadastrada.
        </p>

        <div class="alert alert-info">
            <div class="fw-semibold mb-2">O que sera clonado</div>
            <ul class="mb-0">
                <li>Configuracoes gerais do torneio, incluindo descricao, observacoes internas, cor primaria, logo e regras do ranking.</li>
                <li>Terminologias e comportamento do torneio, como labels, modo de sorteio, configuracoes publicas e configuracoes financeiras.</li>
                <li>Fiscais, embarcacoes, pescadores e premios cadastrados no torneio de origem.</li>
            </ul>
        </div>

        <div class="alert alert-warning">
            <div class="fw-semibold mb-2">O que nao sera clonado</div>
            <ul class="mb-0">
                <li>Capturas registradas no torneio atual.</li>
                <li>Resultados de sorteios ja executados.</li>
                <li>Historicos operacionais, logs e relatorios gerados.</li>
                <li>Banners globais da plataforma.</li>
            </ul>
        </div>

        <div class="alert alert-secondary">
            <div class="fw-semibold mb-2">Importante</div>
            <ul class="mb-0">
                <li>O slug do novo torneio precisa ser unico e sera usado na URL publica e administrativa.</li>
                <li>Depois da clonagem, o novo torneio pode ser ajustado sem alterar o torneio de origem.</li>
            </ul>
        </div>

        <form method="post" action="/@slug/admin/clonar">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-semibold">Slug do novo torneio</label>
                <input type="text" name="novoSlug" class="form-control" required
                       placeholder="ex: pescaria2026" pattern="^[a-z0-9\-]+$"
                       title="Somente letras minusculas, numeros e hifens" />
                <div class="form-text">Sera usado na URL: torvia.ari.net.br/<em>slug</em></div>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">Nome do novo torneio</label>
                <input type="text" name="novoNome" class="form-control" required
                       placeholder="ex: Torneio de Pesca" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-copy me-1"></i>Clonar
                </button>
                <a href="/@slug/admin" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
