@{
    ViewData["Title"] = "Torneio não encontrado";
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
    var slug = ViewContext.RouteData.Values["slug"]?.ToString();
    var outrosTorneios = ViewBag.OutrosTorneios as List<Torneio.Application.DTOs.Torneio.TorneioDto> ?? new();
    var torneio = ViewBag.Torneio as Torneio.Application.DTOs.Torneio.TorneioDto;
}

<div class="row justify-content-center mt-4">
    <div class="col-sm-10 col-md-7 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h5 class="card-title mb-1">
                    <i class="bi bi-exclamation-circle text-warning me-2"></i>Você não está neste torneio
                </h5>
                <p class="text-muted small mb-4">
                    Você está logado, mas não possui cadastro em <strong>@(torneio?.NomeTorneio ?? slug)</strong>.
                </p>

                @if (outrosTorneios.Count > 0)
                {
                    <p class="small fw-semibold mb-2">Seus torneios:</p>
                    <div class="list-group mb-4">
                        @foreach (var t in outrosTorneios)
                        {
                            <a href="/@t.Slug/pescador" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                                <i class="bi bi-trophy text-primary"></i>
                                <span>@t.NomeTorneio</span>
                                <i class="bi bi-chevron-right ms-auto text-muted small"></i>
                            </a>
                        }
                    </div>
                }

                <form method="post" action="/@slug/pescador/sair" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Sair
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
