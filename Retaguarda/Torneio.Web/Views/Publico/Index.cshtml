@model IEnumerable<AnoTorneioDto>
@{
    var torneio = (TorneioDto)ViewBag.Torneio;
    ViewData["Title"] = torneio.NomeTorneio;
}

<h1>@torneio.NomeTorneio</h1>

<h4 class="mt-4">Edições</h4>
@if (!Model.Any())
{
    <p class="text-muted">Nenhuma edição cadastrada.</p>
}
else
{
    <table class="table">
        <thead>
            <tr><th>Ano</th><th>Status</th></tr>
        </thead>
        <tbody>
            @foreach (var a in Model.OrderByDescending(x => x.Ano))
            {
                var badgeClass = a.Status switch
                {
                    "Liberado"   => "bg-success",
                    "Finalizado" => "bg-secondary",
                    _            => "bg-warning text-dark"
                };
                <tr>
                    <td>@a.Ano</td>
                    <td><span class="badge @badgeClass">@a.Status</span></td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a href="/@torneio.Slug/login" class="btn btn-outline-primary">Entrar como administrador</a>
</div>
