@model TorneioDto
@{
    ViewData["Title"] = Model.NomeTorneio;

    var badgeClass = Model.Status switch
    {
        "Liberado"   => "bg-success",
        "Finalizado" => "bg-secondary",
        _            => "bg-warning text-dark"
    };
}

<h1>@Model.NomeTorneio</h1>
<p class="mt-2">
    <span class="badge @badgeClass">@Model.Status</span>
</p>

<div class="mt-3">
    <a href="/@Model.Slug/login" class="btn btn-outline-primary">Entrar como administrador</a>
</div>
