@model TorneioDto
@{
    ViewData["Title"] = Model.NomeTorneio;
    var storageBase = ViewBag.StorageBaseUrl as string ?? "";
    var patrocinadores = ((IEnumerable<PatrocinadorDto>?)ViewBag.Patrocinadores ?? Enumerable.Empty<PatrocinadorDto>())
        .Where(p => p.ExibirNaTelaInicial)
        .OrderBy(p => p.Nome)
        .ToList();
    var participantes = ((IEnumerable<Torneio.Application.DTOs.Membro.MembroDto>?)ViewBag.Participantes ?? Enumerable.Empty<Torneio.Application.DTOs.Membro.MembroDto>())
        .OrderBy(m => m.Nome)
        .ToList();

    var badgeClass = Model.Status switch
    {
        "Liberado"   => "bg-success",
        "Finalizado" => "bg-secondary",
        _            => "bg-warning text-dark"
    };

    var exibirRanking        = Model.Status is "Liberado" or "Finalizado";
    var exibirRankingEquipe  = exibirRanking && Model.PremiacaoPorEquipe;
    var rankingEquipes  = ViewBag.RankingEquipes  as List<RankingEquipeVm> ?? [];
    var rankingMembros  = ViewBag.RankingMembros  as List<RankingMembroVm> ?? [];
    var usarFator       = (bool)(ViewBag.UsarFator ?? false);
    var medida          = (string)(ViewBag.MedidaCaptura ?? "cm");
    var labelEquipePlural  = (string)(ViewBag.LabelEquipePlural ?? "Equipes");
    var labelMembroPlural  = (string)(ViewBag.LabelMembroPlural ?? "Pescadores");
    var labelItem          = (string)(ViewBag.LabelItem  ?? "Item");
    var labelCaptura       = (string)(ViewBag.LabelCaptura ?? "Captura");
}

@functions {
    private static bool TemValor(string? valor) => !string.IsNullOrWhiteSpace(valor);

    private static string NormalizarSite(string valor)
    {
        var url = valor.Trim();
        return url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || url.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
            ? url
            : $"https://{url}";
    }

    private static string NormalizarInstagram(string valor)
    {
        var handle = valor.Trim()
            .Replace("https://instagram.com/", "", StringComparison.OrdinalIgnoreCase)
            .Replace("https://www.instagram.com/", "", StringComparison.OrdinalIgnoreCase)
            .Replace("@", "");
        var slash = handle.IndexOf('/');
        if (slash >= 0)
            handle = handle[..slash];
        return $"https://instagram.com/{handle}";
    }

    private static string NormalizarFacebook(string valor)
    {
        var url = valor.Trim();
        if (url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || url.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return url;
        url = url.Replace("facebook.com/", "", StringComparison.OrdinalIgnoreCase)
            .Replace("www.facebook.com/", "", StringComparison.OrdinalIgnoreCase)
            .Replace("@", "")
            .Trim('/');
        return $"https://facebook.com/{url}";
    }

    private static string NormalizarZap(string valor)
    {
        var digitos = new string(valor.Where(char.IsDigit).ToArray());
        return $"https://wa.me/{digitos}";
    }
}

@if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
{
    <div class="mb-3">
        <img src="@Model.LogoUrl" alt="@Model.NomeTorneio" style="max-height:150px;max-width:220px;object-fit:contain;" />
    </div>
}
<h1>@Model.NomeTorneio</h1>
<p class="mt-2">
    <span class="badge @badgeClass">@Model.Status</span>
</p>

<div class="mt-3">
    <a href="/@Model.Slug/login" class="btn btn-outline-primary">Entrar como administrador</a>
    @if (Model.PermitirRegistroPublicoMembro)
    {
        <a href="/@Model.Slug/membro/login" class="btn btn-outline-secondary ms-2">Entrar como @Model.LabelMembro.ToLower()</a>
        <a href="/@Model.Slug/membro/recuperar-senha" class="btn btn-outline-dark ms-2">Recuperar senha do @Model.LabelMembro.ToLower()</a>
        <a href="/@Model.Slug/registro-membro" class="btn btn-primary ms-2">Registrar @Model.LabelMembro.ToLower()</a>
    }
</div>

@if (exibirRanking)
{
    <div class="row g-4 mt-1">

        @* Ranking por equipe *@
        @if (exibirRankingEquipe)
        {
        <div class="col-lg-5">
            <div class="content-card h-100">
                <div class="card-header-bar">
                    <h5><i class="bi bi-trophy me-2 text-warning"></i>Ranking por @labelEquipePlural</h5>
                </div>
                @if (!rankingEquipes.Any())
                {
                    <div class="card-body-pad text-muted">Nenhuma captura registrada ainda.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th style="width:44px">#</th>
                                    <th style="width:44px"></th>
                                    <th>@labelEquipePlural</th>
                                    <th class="text-end">Pontos</th>
                                    <th class="text-end">@labelCaptura&#x28;s&#x29;</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in rankingEquipes)
                                {
                                    var medalha = r.Posicao switch { 1 => "🥇", 2 => "🥈", 3 => "🥉", _ => $"{r.Posicao}º" };
                                    var fotoEq  = string.IsNullOrWhiteSpace(r.FotoUrl) ? null
                                        : (r.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? r.FotoUrl : $"{storageBase}/{r.FotoUrl.TrimStart('/')}");
                                    <tr class="@(r.Posicao <= 3 ? "fw-semibold" : "")">
                                        <td class="text-center" style="font-size:3rem">@medalha</td>
                                        <td>
                                            @if (fotoEq != null)
                                            {
                                                <img src="@fotoEq" alt="@r.NomeEquipe"
                                                     class="rounded-circle foto-thumb"
                                                     style="width:104px;height:104px;object-fit:cover;cursor:pointer;flex-shrink:0;"
                                                     data-src="@fotoEq" data-nome="@r.NomeEquipe"
                                                     onerror="this.style.visibility='hidden'" />
                                            }
                                            else
                                            {
                                                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary text-white"
                                                      style="width:104px;height:104px;font-size:2.2rem;flex-shrink:0">
                                                    <i class="bi bi-people"></i>
                                                </span>
                                            }
                                        </td>
                                        <td style="font-size:2rem">@r.NomeEquipe</td>
                                        <td class="text-end fw-bold" style="font-size:2rem">@r.TotalPontos.ToString("0.##")</td>
                                        <td class="text-end text-muted" style="font-size:2rem">@r.QtdCapturas</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        }

        @* Ranking por membro *@
        <div class="@(exibirRankingEquipe ? "col-lg-7" : "col-12")">
            <div class="content-card h-100">
                <div class="card-header-bar">
                    <h5><i class="bi bi-person-lines-fill me-2 text-primary"></i>Ranking por @labelMembroPlural</h5>
                </div>
                @if (!rankingMembros.Any())
                {
                    <div class="card-body-pad text-muted">Nenhuma captura registrada ainda.</div>
                }
                else
                {
                    <div class="accordion accordion-flush" id="accordionMembros">
                        @foreach (var r in rankingMembros)
                        {
                            var medalha   = r.Posicao switch { 1 => "🥇", 2 => "🥈", 3 => "🥉", _ => $"{r.Posicao}º" };
                            var accordId  = $"membro-{r.Posicao}";
                            var fotoMb    = string.IsNullOrWhiteSpace(r.FotoUrl) ? null
                                : (r.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? r.FotoUrl : $"{storageBase}/{r.FotoUrl.TrimStart('/')}");
                            <div class="accordion-item border-0 border-bottom">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed @(r.Posicao <= 3 ? "fw-semibold" : "")"
                                            type="button" data-bs-toggle="collapse"
                                            data-bs-target="#@accordId" aria-expanded="false"
                                            style="padding-top:2rem;padding-bottom:2rem">
                                        <span class="me-2" style="min-width:72px;font-size:3rem">@medalha</span>
                                        @if (fotoMb != null)
                                        {
                                            <img src="@fotoMb" alt="@r.NomeMembro"
                                                 class="rounded-circle me-2 foto-thumb"
                                                 style="width:96px;height:96px;object-fit:cover;cursor:pointer;flex-shrink:0;"
                                                 data-src="@fotoMb" data-nome="@r.NomeMembro"
                                                 onerror="this.style.visibility='hidden'" />
                                        }
                                        else
                                        {
                                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary text-white me-2"
                                                  style="width:96px;height:96px;font-size:2.2rem;flex-shrink:0">
                                                <i class="bi bi-person"></i>
                                            </span>
                                        }
                                        <span class="flex-fill" style="font-size:2rem">@r.NomeMembro <span class="text-muted fw-normal ms-1">@r.NomeEquipe</span></span>
                                        <span class="badge bg-primary ms-2" style="font-size:2rem">@r.TotalPontos.ToString("0.##") pts</span>
                                    </button>
                                </h2>
                                <div id="@accordId" class="accordion-collapse collapse" data-bs-parent="#accordionMembros">
                                    <div class="accordion-body p-0">
                                        <table class="table table-sm table-hover mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>@labelItem</th>
                                                    <th>Medida (@medida)</th>
                                                    @if (usarFator)
                                                    {
                                                        <th>Fator</th>
                                                    }
                                                    <th>Pontos</th>
                                                    <th>Data/Hora</th>
                                                    <th>Foto</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var cap in r.Capturas)
                                                {
                                                    var fotoCapUrl = string.IsNullOrWhiteSpace(cap.FotoUrl) ? null
                                                        : (cap.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? cap.FotoUrl : $"{storageBase}/{cap.FotoUrl.TrimStart('/')}");
                                                    <tr>
                                                        <td class="fw-semibold" style="font-size:2rem">@cap.NomeItem</td>
                                                        <td style="font-size:2rem">@cap.TamanhoMedida.ToString("0.##")</td>
                                                        @if (usarFator)
                                                        {
                                                            <td class="text-muted" style="font-size:2rem">@(cap.FatorMultiplicador > 1m ? cap.FatorMultiplicador.ToString("0.##") : "—")</td>
                                                        }
                                                        <td class="fw-semibold" style="font-size:2rem">@cap.Pontuacao.ToString("0.##")</td>
                                                        <td class="text-muted" style="font-size:2rem">@cap.DataHora.ToString("dd/MM HH:mm")</td>
                                                        <td>
                                                            @if (fotoCapUrl != null)
                                                            {
                                                                <img src="@fotoCapUrl" alt="foto"
                                                                     class="foto-thumb"
                                                                     style="width:96px;height:96px;object-fit:cover;border-radius:12px;cursor:pointer;"
                                                                     data-src="@fotoCapUrl"
                                                                     data-nome="@r.NomeMembro - @cap.NomeItem"
                                                                     onerror="this.style.visibility='hidden'" />
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">—</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- Modal zoom foto -->
    <div class="modal fade" id="modalFotoPublico" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 bg-transparent shadow-none">
                <div class="modal-body p-0 text-center">
                    <img id="modalFotoPublicoImg" src="" alt="" class="img-fluid rounded" style="max-height:80vh;" />
                    <p id="modalFotoPublicoNome" class="text-white mt-2 fw-semibold fs-5 mb-0"></p>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
        (() => {
            const modal     = new bootstrap.Modal(document.getElementById('modalFotoPublico'));
            const modalImg  = document.getElementById('modalFotoPublicoImg');
            const modalNome = document.getElementById('modalFotoPublicoNome');
            document.querySelectorAll('.foto-thumb').forEach(img => {
                img.addEventListener('click', e => {
                    e.stopPropagation();
                    modalImg.src = img.dataset.src;
                    modalImg.alt = img.dataset.nome;
                    modalNome.textContent = img.dataset.nome;
                    modal.show();
                });
            });
        })();
        </script>
    }
}

@if (Model.ExibirParticipantesPublicos && participantes.Any())
{
    <div class="content-card mt-4">
        <div class="card-header-bar">
            <h5><i class="bi bi-people me-2"></i>Participantes</h5>
        </div>
        <div class="card-body-pad">
            <div class="mb-3 text-muted fw-semibold">@participantes.Count @Model.LabelMembroPlural.ToLower() cadastrados</div>
            <div class="row g-3">
                @foreach (var participante in participantes)
                {
                    var fotoUrl = string.IsNullOrWhiteSpace(participante.FotoUrl)
                        ? null
                        : (participante.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                            ? participante.FotoUrl
                            : $"{storageBase}/{participante.FotoUrl.TrimStart('/')}");
                    <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 col-6">
                        <div class="border rounded-3 p-3 h-100 bg-white d-flex flex-column align-items-center text-center gap-2">
                            @if (fotoUrl != null)
                            {
                                <img src="@fotoUrl"
                                     alt="@participante.Nome"
                                     class="rounded-circle foto-thumb"
                                     style="width:96px;height:96px;object-fit:cover;cursor:pointer;flex-shrink:0;"
                                     data-src="@fotoUrl"
                                     data-nome="@participante.Nome"
                                     onerror="this.style.visibility='hidden'" />
                            }
                            else
                            {
                                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-secondary text-white"
                                      style="width:96px;height:96px;font-size:2rem;">
                                    <i class="bi bi-person"></i>
                                </span>
                            }
                            <div class="fw-semibold">@participante.Nome</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (patrocinadores.Any())
{
    <div class="content-card mt-4">
        <div class="card-header-bar">
            <h5><i class="bi bi-megaphone me-2"></i>Apoio e Patrocinadores</h5>
        </div>
        <div class="card-body-pad">
            <div class="row g-3">
                @foreach (var patrocinador in patrocinadores)
                {
                    var fotoUrl = patrocinador.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                        ? patrocinador.FotoUrl
                        : $"{storageBase}/{patrocinador.FotoUrl.TrimStart('/')}";
                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <div class="border rounded-3 p-3 h-100 bg-white d-flex flex-column gap-3 align-items-center">
                            <div class="w-100 d-flex justify-content-center">
                                <img src="@fotoUrl"
                                     alt="@patrocinador.Nome"
                                     style="width:100%;max-width:220px;height:130px;object-fit:contain;border-radius:14px;border:1px solid #e2e8f0;background:#fff;" />
                            </div>
                            <div class="d-flex flex-wrap justify-content-center gap-2">
                                @if (TemValor(patrocinador.Site))
                                {
                                    <a href="@NormalizarSite(patrocinador.Site!)" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-globe me-1"></i>Site
                                    </a>
                                }
                                @if (TemValor(patrocinador.Instagram))
                                {
                                    <a href="@NormalizarInstagram(patrocinador.Instagram!)" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-dark">
                                        <i class="bi bi-instagram me-1"></i>Instagram
                                    </a>
                                }
                                @if (TemValor(patrocinador.Facebook))
                                {
                                    <a href="@NormalizarFacebook(patrocinador.Facebook!)" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-facebook me-1"></i>Facebook
                                    </a>
                                }
                                @if (TemValor(patrocinador.Zap))
                                {
                                    <a href="@NormalizarZap(patrocinador.Zap!)" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-whatsapp me-1"></i>Zap
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
