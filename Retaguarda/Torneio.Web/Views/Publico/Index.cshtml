@model TorneioDto
@{
    ViewData["Title"] = Model.NomeTorneio;
    var storageBase = ViewBag.StorageBaseUrl as string ?? "";
    var patrocinadores = ((IEnumerable<PatrocinadorDto>?)ViewBag.Patrocinadores ?? Enumerable.Empty<PatrocinadorDto>())
        .Where(p => p.ExibirNaTelaInicial)
        .OrderBy(p => p.Nome)
        .ToList();

    var badgeClass = Model.Status switch
    {
        "Liberado"   => "bg-success",
        "Finalizado" => "bg-secondary",
        _            => "bg-warning text-dark"
    };
}

@functions {
    private static bool TemValor(string? valor) => !string.IsNullOrWhiteSpace(valor);

    private static string NormalizarSite(string valor)
    {
        var url = valor.Trim();
        return url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || url.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
            ? url
            : $"https://{url}";
    }

    private static string NormalizarInstagram(string valor)
    {
        var handle = valor.Trim()
            .Replace("https://instagram.com/", "", StringComparison.OrdinalIgnoreCase)
            .Replace("https://www.instagram.com/", "", StringComparison.OrdinalIgnoreCase)
            .Replace("@", "");
        var slash = handle.IndexOf('/');
        if (slash >= 0)
            handle = handle[..slash];
        return $"https://instagram.com/{handle}";
    }

    private static string NormalizarFacebook(string valor)
    {
        var url = valor.Trim();
        if (url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || url.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return url;
        url = url.Replace("facebook.com/", "", StringComparison.OrdinalIgnoreCase)
            .Replace("www.facebook.com/", "", StringComparison.OrdinalIgnoreCase)
            .Replace("@", "")
            .Trim('/');
        return $"https://facebook.com/{url}";
    }

    private static string NormalizarZap(string valor)
    {
        var digitos = new string(valor.Where(char.IsDigit).ToArray());
        return $"https://wa.me/{digitos}";
    }
}

@if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
{
    <div class="mb-3">
        <img src="@Model.LogoUrl" alt="@Model.NomeTorneio" style="max-height:90px;max-width:220px;object-fit:contain;" />
    </div>
}
<h1>@Model.NomeTorneio</h1>
<p class="mt-2">
    <span class="badge @badgeClass">@Model.Status</span>
</p>

<div class="mt-3">
    <a href="/@Model.Slug/login" class="btn btn-outline-primary">Entrar como administrador</a>
    @if (Model.PermitirRegistroPublicoMembro)
    {
        <a href="/@Model.Slug/membro/login" class="btn btn-outline-secondary ms-2">Entrar como @Model.LabelMembro.ToLower()</a>
        <a href="/@Model.Slug/membro/recuperar-senha" class="btn btn-outline-dark ms-2">Recuperar senha do @Model.LabelMembro.ToLower()</a>
        <a href="/@Model.Slug/registro-membro" class="btn btn-primary ms-2">Registrar @Model.LabelMembro.ToLower()</a>
    }
</div>

@if (patrocinadores.Any())
{
    <div class="content-card mt-4">
        <div class="card-header-bar">
            <h5><i class="bi bi-megaphone me-2"></i>Patrocinadores</h5>
        </div>
        <div class="card-body-pad">
            <div class="row g-3">
                @foreach (var patrocinador in patrocinadores)
                {
                    var fotoUrl = patrocinador.FotoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                        ? patrocinador.FotoUrl
                        : $"{storageBase}/{patrocinador.FotoUrl.TrimStart('/')}";
                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <div class="border rounded-3 p-3 h-100 bg-white d-flex flex-column gap-3 align-items-center">
                            <div class="w-100 d-flex justify-content-center">
                                <img src="@fotoUrl"
                                     alt="@patrocinador.Nome"
                                     style="width:100%;max-width:220px;height:130px;object-fit:contain;border-radius:14px;border:1px solid #e2e8f0;background:#fff;" />
                            </div>
                            <div class="d-flex flex-wrap justify-content-center gap-2">
                                @if (TemValor(patrocinador.Site))
                                {
                                    <a href="@NormalizarSite(patrocinador.Site!)" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-globe me-1"></i>Site
                                    </a>
                                }
                                @if (TemValor(patrocinador.Instagram))
                                {
                                    <a href="@NormalizarInstagram(patrocinador.Instagram!)" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-dark">
                                        <i class="bi bi-instagram me-1"></i>Instagram
                                    </a>
                                }
                                @if (TemValor(patrocinador.Facebook))
                                {
                                    <a href="@NormalizarFacebook(patrocinador.Facebook!)" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-facebook me-1"></i>Facebook
                                    </a>
                                }
                                @if (TemValor(patrocinador.Zap))
                                {
                                    <a href="@NormalizarZap(patrocinador.Zap!)" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-whatsapp me-1"></i>Zap
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
