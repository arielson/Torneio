@model IEnumerable<AnoTorneioDto>
@{
    var slug = Context.GetRouteData().Values["slug"]?.ToString();
    ViewData["Title"] = "Sorteio";
    var lista = Model.OrderByDescending(x => x.Ano).ToList();
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Sorteio</h1>
    </div>
</div>
<a href="/@slug/admin" class="back-link">
    <i class="bi bi-arrow-left"></i> Painel
</a>

<div class="content-card" style="max-width:480px">
    <div class="card-header-bar">
        <h5><i class="bi bi-shuffle me-2"></i>Selecione o Ano</h5>
    </div>
    @if (!lista.Any())
    {
        <div class="card-body-pad text-muted">Nenhum ano cadastrado.</div>
    }
    else
    {
        <ul class="list-group list-group-flush">
            @foreach (var a in lista)
            {
                var badgeClass = a.Status switch
                {
                    "Liberado"   => "bg-success-subtle text-success border-success-subtle",
                    "Finalizado" => "bg-secondary-subtle text-secondary border-secondary-subtle",
                    _            => "bg-warning-subtle text-warning border-warning-subtle"
                };
                <li class="list-group-item d-flex justify-content-between align-items-center px-4 py-3">
                    <span class="fw-semibold">
                        @a.Ano
                        <span class="badge border @badgeClass ms-2">@a.Status</span>
                    </span>
                    <a href="/@slug/sorteio/@a.Id" class="btn btn-sm btn-primary">
                        <i class="bi bi-arrow-right me-1"></i>Abrir
                    </a>
                </li>
            }
        </ul>
    }
</div>
