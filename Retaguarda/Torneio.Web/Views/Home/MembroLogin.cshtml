@model MembroLoginViewModel
@{
    ViewData["Title"] = $"Entrar como pescador - {Model.NomeTorneio}";
    ViewData["IsAuthPage"] = true;
}

<div class="auth-card">
    <div class="auth-logo">
        <i class="bi bi-person-badge-fill"></i>
    </div>
    <h2>@Model.NomeTorneio</h2>
    <p class="auth-subtitle">Acesso do pescador para consultar suas cobranças</p>

    <form asp-action="MembroLogin" asp-route-slug="@Model.Slug" method="post">
        <input type="hidden" asp-for="ReturnUrl" />
        <input type="hidden" asp-for="Slug" />
        <input type="hidden" asp-for="NomeTorneio" />
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3 small"></div>
        }

        <div class="mb-3">
            <label asp-for="Usuario" class="form-label">Usuário</label>
            <input asp-for="Usuario" class="form-control" autocomplete="username" />
            <span asp-validation-for="Usuario" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="Senha" class="form-label">Senha</label>
            <input asp-for="Senha" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="Senha" class="text-danger small"></span>
        </div>
        <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
        </button>
    </form>

    <div class="text-center mt-3">
        <div class="mb-2">
            <a href="/@Model.Slug/pescador/recuperar-senha" class="small">Esqueci minha senha</a>
        </div>
        <div class="mb-2">
            <a href="/@Model.Slug/registro-pescador" class="small">Quero me registrar</a>
        </div>
        <a href="/@Model.Slug" class="text-muted small">
            <i class="bi bi-arrow-left me-1"></i>Voltar ao torneio
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
